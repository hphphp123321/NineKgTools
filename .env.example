# NineKgTools 环境变量示例
# 复制为 .env 后填入实际值：cp .env.example .env

# ─── 必填 ────────────────────────────────────────────────────
# OpenAI 接入（启用 AI 识别 / 向量搜索时必填）
# 也可从兼容 OpenAI 协议的代理（zhizengzeng / openai-sb / 等）申请
OPENAI_API_KEY=

# ─── 可选 ────────────────────────────────────────────────────
# 时区（影响日志时间戳、Hangfire 定时任务的 cron 解析）
TZ=Asia/Shanghai

# 初始管理员账号（首次启动时若数据库无用户则用这两个创建 admin）
# 留空则使用默认 admin / admin
NT_USER=admin
NT_PASSWORD=admin

# ─── 危险操作 ──────────────────────────────────────────────────
# 设为 true 时启动会**删除整个数据库**重建——请务必先备份 ./data 目录
# 默认 false。compose 文件已硬编码 false，覆盖此处后需重启
# NINEKG_RESET_DB=false
