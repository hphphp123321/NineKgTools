@page "/settings"
<PageTitle>系统设置</PageTitle>

@using NineKgTools.Components.Common
@using NineKgTools.Core.Services.AI
@using NineKgTools.Core.Services.Configs
@using NineKgTools.Core.Models.Tasks
@using NineKgTools.Core.Models.Identification
@using Serilog
@using Serilog.Events

@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudGrid>
        <!-- 页面标题 -->
        <MudItem xs="12">
            <PageHeader Icon="@Icons.Material.Filled.Settings"
                        IconColor="Color.Primary"
                        Title="系统设置"
                        Subtitle="配置应用程序的各项参数和功能">
                <Actions>
                    <MudButton OnClick="_resetAllConfig"
                               StartIcon="@Icons.Material.Filled.RestartAlt"
                               Color="Color.Warning"
                               Variant="Variant.Outlined"
                               Size="Size.Medium">
                        重置全部
                    </MudButton>
                    <MudButton Disabled="@_saveProcessing" OnClick="_saveAllConfig"
                               StartIcon="@(!_saveProcessing ? Icons.Material.Filled.Save : null)"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Size="Size.Medium">
                        @if (_saveProcessing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">保存中</MudText>
                        }
                        else
                        {
                            <MudText>保存全部</MudText>
                        }
                    </MudButton>
                </Actions>
            </PageHeader>
        </MudItem>

        <!-- 设置标签页 -->
        <MudItem xs="12">
            <MudCard Elevation="0" Class="@($"modern-tabs-container{(_isTabTransitioning ? " is-tab-transitioning" : "")}")">
                <MudTabs Elevation="0" Rounded="true" PanelClass="settings-tab-content pa-6"
                         ActivePanelIndex="_activeTabIndex" ActivePanelIndexChanged="_onTabChanged"
                         Color="Color.Primary" SliderColor="Color.Primary" Position="Position.Top"
                         TabHeaderClass="modern-tabs-header"
                         KeepPanelsAlive="false" ApplyEffectsToContainer="true"
                         ActiveTabClass="modern-tab-active"
                         Ripple="false" SliderAnimation="true"
                         Centered="false" Border="false"
                         AlwaysShowScrollButtons="true"
                         NextIcon="@Icons.Material.Filled.ChevronRight"
                         PrevIcon="@Icons.Material.Filled.ChevronLeft"
                         ScrollIconColor="Color.Primary"
                         MinimumTabWidth="120px">
                    
                    <!-- 应用设置标签页 -->
                    <MudTabPanel Text="应用设置" Icon="@Icons.Material.Filled.SettingsApplications">
                        <MudCard Elevation="0" Class="card-bordered-primary mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <div class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Filled.SettingsApplications" Color="Color.Primary" Size="Size.Medium" />
                                        <MudText Typo="Typo.h6" Class="font-weight-semibold">基础配置</MudText>
                                    </div>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-6">
                                <div class="settings-section-header">
                                    <MudIcon Icon="@Icons.Material.Filled.VpnLock" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">代理设置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="_appConfig.Proxy.ProxyAddr"
                                                      Label="代理服务器地址" Variant="Variant.Outlined"
                                                      InputType="@InputType.Url" 
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.VpnLock"
                                                      AdornmentColor="Color.Primary"
                                                      HelperText="代理地址，如：http://127.0.0.1:7890"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_appConfig.Proxy.ProxyUser"
                                                      Label="代理用户名" Variant="Variant.Outlined"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                                      AdornmentColor="Color.Primary"
                                                      HelperText="代理认证用户名（可选）"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudInputPassword
                                            Value="@_appConfig.Proxy.ProxyPassword"
                                            ValueChanged="@((string value) => _appConfig.Proxy.ProxyPassword = value)"
                                            Label="代理密码"
                                            HelperText="代理认证密码（可选）"
                                            Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                                
                                <MudDivider Class="my-4" />
                                <div class="settings-section-header">
                                    <MudIcon Icon="@Icons.Custom.Brands.Chrome" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">浏览器设置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="_appConfig.UserAgent"
                                                      Label="User-Agent" Variant="Variant.Outlined"
                                                      Adornment="Adornment.End"
                                                      OnAdornmentClick="_getUserAgent"
                                                      AdornmentIcon="@Icons.Custom.Brands.Chrome" 
                                                      AdornmentColor="Color.Primary"
                                                      HelperText="用于爬虫，点击右侧图标自动获取当前浏览器的User-Agent"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                                <MudDivider Class="my-4" />
                                <div class="settings-section-header">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">账号管理</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body1" Class="mb-2">
                                            当前用户名: <strong>@_currentUsername</strong>
                                        </MudText>
                                        @if (_lastLoginAt.HasValue)
                                        {
                                            <MudText Typo="Typo.body2" Class="text-secondary">
                                                最后登录时间: @_lastLoginAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                            </MudText>
                                        }
                                    </MudItem>
                                    <MudItem xs="12" Class="d-flex gap-3">
                                        <MudButton OnClick="@(() => _showChangeUsernameDialog = true)"
                                                   Color="Color.Primary" Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.Person"
                                                   Size="Size.Medium">
                                            修改用户名
                                        </MudButton>
                                        <MudButton OnClick="@(() => _showChangePasswordDialog = true)"
                                                   Color="Color.Primary" Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.VpnKey"
                                                   Size="Size.Medium">
                                            修改密码
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                            <MudCardActions Class="d-flex justify-end gap-3 px-6 py-4">
                                <MudButton Disabled="@_testProxyProcessing" OnClick="_testProxy"
                                           StartIcon="@Icons.Material.Filled.NetworkCheck"
                                           Color="Color.Info" Variant="Variant.Outlined"
                                           Size="Size.Medium">
                                    @if (_testProxyProcessing)
                                    {
                                        <MudProgressCircular Size="Size.Small" />
                                        <MudText Class="ml-2">测试代理</MudText>
                                    }
                                    else
                                    {
                                        <MudText>测试代理连接</MudText>
                                    }
                                </MudButton>
                                <MudButton OnClick="@(() => _saveTabConfig("app"))"
                                           Color="Color.Primary" Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Size="Size.Medium">
                                    保存应用设置
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudTabPanel>

                    <!-- 日志配置标签页 -->
                    <MudTabPanel Text="日志配置" Icon="@Icons.Material.Filled.Assignment">
                        <MudCard Elevation="0" Class="card-bordered-info mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <div class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Size="Size.Medium" />
                                        <MudText Typo="Typo.h6" Class="font-weight-semibold">日志输出配置</MudText>
                                    </div>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-6">
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="LogEventLevel" @bind-Value="_logConfig.LogLevel" Label="日志级别" 
                                                   Variant="Variant.Outlined" MultiSelection="false"
                                                   HelperText="设置日志输出的最低级别"
                                                   Margin="Margin.Normal">
                                            <MudSelectItem Value="LogEventLevel.Verbose">Verbose - 详细</MudSelectItem>
                                            <MudSelectItem Value="LogEventLevel.Debug">Debug - 调试</MudSelectItem>
                                            <MudSelectItem Value="LogEventLevel.Information">Information - 信息</MudSelectItem>
                                            <MudSelectItem Value="LogEventLevel.Warning">Warning - 警告</MudSelectItem>
                                            <MudSelectItem Value="LogEventLevel.Error">Error - 错误</MudSelectItem>
                                            <MudSelectItem Value="LogEventLevel.Fatal">Fatal - 致命</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="LogType" @bind-SelectedValues="_selectedLogTypes" Label="输出类型" 
                                                   Variant="Variant.Outlined" MultiSelection="true"
                                                   HelperText="选择日志的输出方式（可多选）"
                                                   Margin="Margin.Normal">
                                            <MudSelectItem Value="LogType.Console">控制台</MudSelectItem>
                                            <MudSelectItem Value="LogType.File">文件</MudSelectItem>
                                            <MudSelectItem Value="LogType.Server">远程服务器</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                </MudGrid>
                                
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_logConfig.LogPath"
                                                      Label="日志文件路径" Variant="Variant.Outlined"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Folder"
                                                      AdornmentColor="Color.Info"
                                                      HelperText="日志文件存储目录"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_logConfig.LogServer"
                                                      Label="日志服务器地址" Variant="Variant.Outlined"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Cloud"
                                                      AdornmentColor="Color.Info"
                                                      HelperText="远程日志服务器地址（如：192.168.1.100:514）"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                                
                                <MudGrid Spacing="4">
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="_logConfig.LogTemplate"
                                                      Label="日志模板" Variant="Variant.Outlined"
                                                      Lines="3" 
                                                      HelperText="自定义日志格式模板"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                            <MudCardActions Class="d-flex justify-end gap-3 px-6 py-4">
                                <MudButton OnClick="@(() => _saveTabConfig("log"))" 
                                           Color="Color.Info" Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Size="Size.Medium">
                                    保存日志配置
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudTabPanel>

                    <!-- AI配置标签页 -->
                    <MudTabPanel Text="AI配置" Icon="@Icons.Material.Filled.Psychology">
                        <MudCard Elevation="0" Class="card-bordered-tertiary mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <div class="d-flex align-center justify-space-between w-100">
                                        <div class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Tertiary" Size="Size.Medium" />
                                            <MudText Typo="Typo.h6" Class="font-weight-semibold">人工智能配置</MudText>
                                        </div>
                                        <MudSwitch T="bool" @bind-Value="_aiConfig.UseAi"
                                                   Label="启用AI功能" Color="Color.Tertiary" 
                                                   LabelPosition="LabelPosition.Start" />
                                    </div>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-6">
                                <div class="settings-section-header settings-section-header-tertiary">
                                    <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Tertiary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">OpenAI配置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudInputPassword
                                            Value="@_aiConfig.OpenAi.ApiKey"
                                            ValueChanged="@((string value) => _aiConfig.OpenAi.ApiKey = value)"
                                            Label="API密钥"
                                            Disabled="@(!_aiConfig.UseAi)"
                                            AdornmentColor="Color.Tertiary"
                                            HelperText="OpenAI API Key，留空则从环境变量获取"
                                            Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_aiConfig.OpenAi.BaseDomain"
                                                      Label="API端点" Variant="Variant.Outlined"
                                                      InputType="@InputType.Url"
                                                      Disabled="@(!_aiConfig.UseAi)"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Language"
                                                      AdornmentColor="Color.Tertiary"
                                                      HelperText="API服务端点地址"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                                
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="string" @bind-Value="_aiConfig.OpenAi.DefaultModel"
                                                        Label="默认模型" Variant="Variant.Outlined"
                                                        SearchFunc="@_listAIModels" 
                                                        Disabled="@(!_aiConfig.UseAi)"
                                                        ShowProgressIndicator="true"
                                                        HelperText="AI使用的默认模型"
                                                        Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_aiConfig.OpenAi.ApiVersion"
                                                      Label="API版本" Variant="Variant.Outlined"
                                                      Disabled="@(!_aiConfig.UseAi)"
                                                      HelperText="API版本号"
                                                      Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                                
                                <MudDivider Class="my-4" />
                                <div class="settings-section-header settings-section-header-tertiary">
                                    <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Tertiary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">向量功能配置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Value="_aiConfig.Vector.Enable"
                                                   Color="Color.Tertiary" Disabled="@(!_aiConfig.UseAi)"
                                                   LabelPosition="LabelPosition.End">
                                            <span class="switch-label-with-tip">
                                                启用向量存储
                                                <Tip Text="启用后系统会使用向量数据库存储AI生成的向量数据，这是使用语义搜索、向量匹配等高级AI功能的前提条件。需要先启用AI功能。"
                                                     Placement="Placement.Right"
                                                     IconColor="Color.Info" />
                                            </span>
                                        </MudSwitch>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Value="_aiConfig.UseAiForKeywordSplitting"
                                                   Color="Color.Tertiary" Disabled="@(!_aiConfig.UseAi)"
                                                   LabelPosition="LabelPosition.End">
                                            <span class="switch-label-with-tip">
                                                AI关键词分割
                                                <Tip Text="启用后系统会使用AI技术对媒体标题和描述进行智能关键词分割和提取，提高标签识别的准确性。需要先启用AI功能。"
                                                     Placement="Placement.Right"
                                                     IconColor="Color.Info" />
                                            </span>
                                        </MudSwitch>
                                    </MudItem>
                                </MudGrid>

                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Value="_aiConfig.Vector.Media.Enable"
                                                   Color="Color.Tertiary"
                                                   LabelPosition="LabelPosition.End"
                                                   Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable)">
                                            <span class="switch-label-with-tip">
                                                启用媒体向量
                                                <Tip Text="@GetMediaVectorIndexingTipText()"
                                                     Placement="Placement.Right"
                                                     IconColor="@(_aiConfig.UseAi && _aiConfig.Vector.Enable ? Color.Info : Color.Warning)" />
                                            </span>
                                        </MudSwitch>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Value="_aiConfig.Vector.Tag.Enable"
                                                   Color="Color.Tertiary"
                                                   LabelPosition="LabelPosition.End"
                                                   Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable)">
                                            <span class="switch-label-with-tip">
                                                启用标签向量
                                                <Tip Text="@GetTagVectorMatchingTipText()"
                                                     Placement="Placement.Right"
                                                     IconColor="@(_aiConfig.UseAi && _aiConfig.Vector.Enable ? Color.Info : Color.Warning)" />
                                            </span>
                                        </MudSwitch>
                                    </MudItem>
                                </MudGrid>

                                <MudDivider Class="my-4" />
                                <div class="settings-section-header settings-section-header-tertiary">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Tertiary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">向量参数设置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="double" @bind-Value="_aiConfig.Vector.Media.MinSimilarity"
                                                       Label="媒体搜索最小相似度" Variant="Variant.Outlined"
                                                       Min="0.01" Max="1.0" Step="0.05"
                                                       Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable || !_aiConfig.Vector.Media.Enable)"
                                                       HelperText="媒体向量搜索的最小相似度阈值（0-1）"
                                                       Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="double" @bind-Value="_aiConfig.Vector.Tag.SimilarityThreshold"
                                                       Label="标签匹配相似度阈值" Variant="Variant.Outlined"
                                                       Min="0.01" Max="1.0" Step="0.01"
                                                       Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable || !_aiConfig.Vector.Tag.Enable)"
                                                       HelperText="标签向量匹配的相似度阈值（0-1）"
                                                       Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>

                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="int" @bind-Value="_aiConfig.Vector.Tag.SearchTopK"
                                                       Label="标签搜索TopK" Variant="Variant.Outlined"
                                                       Min="1" Max="10" Step="1"
                                                       Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable || !_aiConfig.Vector.Tag.Enable)"
                                                       HelperText="标签向量搜索返回的最大结果数"
                                                       Margin="Margin.Normal" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="double" @bind-Value="_aiConfig.Vector.Search.Weight"
                                                       Label="向量搜索权重" Variant="Variant.Outlined"
                                                       Min="0.1" Max="1.0" Step="0.1"
                                                       Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable)"
                                                       HelperText="向量搜索在综合结果中的权重（0-1）"
                                                       Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>

                                <MudDivider Class="my-4" />
                                <div class="settings-section-header settings-section-header-tertiary">
                                    <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Tertiary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">向量数据库配置</MudText>
                                </div>
                                <MudGrid Spacing="4">
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="int" @bind-Value="_aiConfig.Vector.Db.BatchSize"
                                                       Label="批处理大小" Variant="Variant.Outlined"
                                                       Min="10" Max="1000" Step="10"
                                                       Disabled="@(!_aiConfig.UseAi || !_aiConfig.Vector.Enable)"
                                                       HelperText="批量处理的数据条目数"
                                                       Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                            <MudCardActions Class="d-flex justify-end gap-3 px-6 py-4">
                                <MudButton Disabled="@(_testAIProcessing || !_aiConfig.UseAi)" 
                                           OnClick="_testAI" Color="Color.Tertiary" Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.SmartToy" Size="Size.Medium">
                                    @if (_testAIProcessing)
                                    {
                                        <MudProgressCircular Size="Size.Small" />
                                        <MudText Class="ml-2">测试中</MudText>
                                    }
                                    else
                                    {
                                        <MudText>测试AI连接</MudText>
                                    }
                                </MudButton>
                                <MudButton Disabled="@(!_aiConfig.UseAi || _listModelsProcessing)" 
                                           OnClick="RefreshAIModels" Color="Color.Tertiary" Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Medium">
                                    @if (_listModelsProcessing)
                                    {
                                        <MudProgressCircular Size="Size.Small" />
                                        <MudText Class="ml-2">刷新中</MudText>
                                    }
                                    else
                                    {
                                        <MudText>刷新模型</MudText>
                                    }
                                </MudButton>
                                <MudButton OnClick="@(() => _saveTabConfig("ai"))" 
                                           Color="Color.Tertiary" Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Size="Size.Medium">
                                    保存AI配置
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudTabPanel>



                    <!-- 文件配置标签页 -->
                    <MudTabPanel Text="文件配置" Icon="@Icons.Material.Filled.Folder">
                        <MudCard Elevation="0" Class="card-bordered-error mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <div class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Error" Size="Size.Medium" />
                                        <MudText Typo="Typo.h6" Class="font-weight-semibold">文件处理配置</MudText>
                                    </div>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-6">
