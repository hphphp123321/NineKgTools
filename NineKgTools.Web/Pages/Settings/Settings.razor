                                    <MudItem xs="12" md="6">
                                        <MudSelect T="IdentificationStrategy" @bind-Value="_identificationConfig.Strategy"
                                                   Label="识别策略" Variant="Variant.Outlined"
                                                   HelperText="选择媒体识别策略"
                                                   Margin="Margin.Normal">
                                            @foreach(var strategy in Enum.GetValues<IdentificationStrategy>())
                                            {
                                                <MudSelectItem T="IdentificationStrategy" Value="@strategy">@strategy</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Value="_identificationConfig.AutoAddToDatabase"
                                                   Color="Color.Warning"
                                                   LabelPosition="LabelPosition.End">
                                            <span class="switch-label-with-tip">
                                                自动添加到数据库
                                                <Tip Text="仅影响后台批量/队列识别任务。关闭后，后台识别结果会进入'待处理'页面的'待入库'列表等待人工确认；手动识别始终要求在 媒体源管理/待处理 页面上人工确认入库。"
                                                     Placement="Placement.Right"
                                                     IconColor="Color.Info" />
                                            </span>
                                        </MudSwitch>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="int" @bind-Value="_identificationConfig.PendingRetentionDays"
                                                         Label="待入库结果保留天数" Variant="Variant.Outlined"
                                                         Min="0" Max="365" Step="1"
                                                         HelperText="超过指定天数未入库的待处理识别结果会被后台自动清理；0 表示永不清理"
                                                         Margin="Margin.Normal" />
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                            <MudCardActions Class="d-flex justify-end gap-3 px-6 py-4">
                                <MudButton OnClick="@(() => _saveTabConfig("identification"))"
                                           Color="Color.Warning" Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Size="Size.Medium">
                                    保存识别配置
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudTabPanel>


                </MudTabs>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- 修改用户名对话框 -->
<MudDialog @bind-Visible="_showChangeUsernameDialog" Options="new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" /> 修改用户名</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudInputPassword
                    Value="@_changeUsernameCurrentPassword"
                    ValueChanged="@((string value) => _changeUsernameCurrentPassword = value)"
                    Label="当前密码"
                    HelperText="请输入当前密码以验证身份" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string" @bind-Value="_newUsername"
                              Label="新用户名" Variant="Variant.Outlined"
                              Required="true"
                              Counter="50" MaxLength="50"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              AdornmentColor="Color.Primary"
                              HelperText="输入新的用户名（2-50个字符）"
                              Margin="Margin.Normal" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { _showChangeUsernameDialog = false; _changeUsernameCurrentPassword = string.Empty; _newUsername = string.Empty; })"
                   Color="Color.Default" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="_changeUsername"
                   Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(_changeUsernameProcessing || string.IsNullOrWhiteSpace(_changeUsernameCurrentPassword) || (_newUsername?.Trim().Length ?? 0) < 2)">
            @if (_changeUsernameProcessing)
            {
                <MudProgressCircular Size="Size.Small" Class="mr-2" />
                <MudText>修改中</MudText>
            }
            else
            {
                <MudText>确认修改</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- 修改密码对话框 -->
<MudDialog @bind-Visible="_showChangePasswordDialog" Options="new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.VpnKey" Class="mr-2" /> 修改密码</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudInputPassword
                    Value="@_changePasswordCurrentPassword"
                    ValueChanged="@((string value) => _changePasswordCurrentPassword = value)"
                    Label="当前密码"
                    HelperText="请输入当前密码" />
            </MudItem>
            <MudItem xs="12">
                <MudInputPassword
                    Value="@_newPassword"
                    ValueChanged="@((string value) => _newPassword = value)"
                    Label="新密码"
                    HelperText="输入新密码（至少4个字符）" />
            </MudItem>
            <MudItem xs="12">
                <MudInputPassword
                    Value="@_confirmNewPassword"
                    ValueChanged="@((string value) => _confirmNewPassword = value)"
                    Label="确认新密码"
                    HelperText="再次输入新密码" />
            </MudItem>
        </MudGrid>
        @if (!string.IsNullOrEmpty(_newPassword) && !string.IsNullOrEmpty(_confirmNewPassword) && _newPassword != _confirmNewPassword)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-3">两次输入的新密码不一致</MudAlert>
        }
        @if (!string.IsNullOrEmpty(_newPassword) && _newPassword.Length < 4)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-3">新密码长度至少为4个字符</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { _showChangePasswordDialog = false; _changePasswordCurrentPassword = string.Empty; _newPassword = string.Empty; _confirmNewPassword = string.Empty; })"
                   Color="Color.Default" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="_changePassword"
                   Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(_changePasswordProcessing || !_isPasswordFormValid)">
            @if (_changePasswordProcessing)
            {
                <MudProgressCircular Size="Size.Small" Class="mr-2" />
                <MudText>修改中</MudText>
            }
            else
            {
                <MudText>确认修改</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
