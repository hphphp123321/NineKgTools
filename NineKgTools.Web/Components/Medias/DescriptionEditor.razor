

<div class="description-editor-container">
    @if (string.IsNullOrEmpty(Description))
    {
        <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
            <div class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.body2">暂无详情描述</MudText>
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Success"
                           Variant="Variant.Text"
                           Size="Size.Small"
                           OnClick="StartEditing">
                    添加描述
                </MudButton>
            </div>
        </MudAlert>
    }
    else
    {
        <div class="description-container rounded-lg">
            @if (!string.IsNullOrEmpty(Description) && !string.IsNullOrEmpty(DescriptionTranslated))
            {
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
                    <MudTabPanel Text="原文" Icon="@Icons.Material.Filled.Language">
                        @if (_isEditing)
                        {
                            <MudTextField @bind-Value="Description"
                                          @bind-Value:after="OnDescriptionChanged"
                                          Label="原文内容 (HTML)"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="15"
                                          AutoGrow="true"
                                          HelperText="支持HTML标签，如 &lt;br/&gt;, &lt;p&gt;, &lt;strong&gt; 等"
                                          Class="html-editor" />
                        }
                        else
                        {
                            <div class="pa-2 description-content">
                                @((MarkupString)Description)
                            </div>
                        }
                    </MudTabPanel>
                    <MudTabPanel Text="翻译" Icon="@Icons.Material.Filled.Translate">
                        @if (_isEditing)
                        {
                            <MudTextField @bind-Value="DescriptionTranslated"
                                          @bind-Value:after="OnDescriptionTranslatedChanged"
                                          Label="翻译内容 (HTML)"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="15"
                                          AutoGrow="true"
                                          HelperText="支持HTML标签，如 &lt;br/&gt;, &lt;p&gt;, &lt;strong&gt; 等"
                                          Class="html-editor" />
                        }
                        else
                        {
                            <div class="pa-2 description-content">
                                @((MarkupString)DescriptionTranslated)
                            </div>
                        }
                    </MudTabPanel>
                </MudTabs>
            }
            else
            {
                @if (_isEditing)
                {
                    <div>
                        <MudTextField @bind-Value="Description"
                                      @bind-Value:after="OnDescriptionChanged"
                                      Label="描述内容 (HTML)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="15"
                                      AutoGrow="true"
                                      HelperText="支持HTML标签，如 &lt;br/&gt;, &lt;p&gt;, &lt;strong&gt; 等"
                                      Class="html-editor" />
                        
                        <div class="d-flex gap-2 mt-3">
                            <MudButton OnClick="SaveDescription"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Color="Color.Success"
                                       Variant="Variant.Filled">
                                保存
                            </MudButton>
                            <MudButton OnClick="CancelEditing"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       Color="Color.Default"
                                       Variant="Variant.Outlined">
                                取消
                            </MudButton>
                        </div>
                    </div>
                }
                else
                {
                    <div class="description-content">
                        @((MarkupString)Description)
                    </div>
                }
            }
        </div>
    }

    <!-- HTML提示面板 -->
    @if (_isEditing)
    {
        <MudExpansionPanels Elevation="0" Class="mt-3">
            <MudExpansionPanel>
                <TitleContent>
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Help" Color="Color.Info" Class="mr-2" />
                        <MudText Typo="Typo.subtitle2" Color="Color.Info">HTML标签帮助</MudText>
                    </div>
                </TitleContent>
                <ChildContent>
                    <div class="pa-3">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">基础标签：</MudText>
                                <div class="d-flex flex-column gap-1">
                                    <MudText Typo="Typo.caption"><code>&lt;p&gt;段落&lt;/p&gt;</code> - 段落</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;br/&gt;</code> - 换行</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;strong&gt;粗体&lt;/strong&gt;</code> - 粗体</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;em&gt;斜体&lt;/em&gt;</code> - 斜体</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">其他标签：</MudText>
                                <div class="d-flex flex-column gap-1">
                                    <MudText Typo="Typo.caption"><code>&lt;h1&gt;标题&lt;/h1&gt;</code> - 标题</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;ul&gt;&lt;li&gt;项目&lt;/li&gt;&lt;/ul&gt;</code> - 列表</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;a href="url"&gt;链接&lt;/a&gt;</code> - 链接</MudText>
                                    <MudText Typo="Typo.caption"><code>&lt;img src="url" alt="描述"/&gt;</code> - 图片</MudText>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</div>

 