@using NineKgTools.Core.Models.Categories

@if (_isLoading)
{
    <div class="d-flex flex-column align-center justify-center pa-6">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium"/>
        <MudText Typo="Typo.body2" Class="mt-3 mud-text-secondary">正在读取目录…</MudText>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Warning" Class="ma-3" Variant="Variant.Outlined">
        @_errorMessage
    </MudAlert>
}
else if (_rootNodes.Count == 0)
{
    <div class="d-flex flex-column align-center justify-center pa-6">
        <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Large" Color="Color.Default"/>
        <MudText Typo="Typo.body2" Class="mt-3 mud-text-secondary">目录为空</MudText>
    </div>
}
else
{
    <MudTreeView T="TreeNode"
                 Items="@_rootNodes"
                 Hover="true"
                 Dense="true"
                 ExpandOnClick="true"
                 Class="pa-2">
        <ItemTemplate Context="context">
            @{
                var node = context.Value;
                var isSelected = node?.FullPath == _selectedFilePath;
                var isHighlighted = IsHighlightedFile(node);
            }
            <MudTreeViewItem T="TreeNode"
                             @bind-Expanded="@context.Expanded"
                             Items="@context.Children"
                             Value="@node"
                             OnClick="@(() => SelectFileAsync(node))"
                             Icon="@GetFileIcon(node)"
                             IconColor="@GetIconColor(node)"
                             Class="@(isSelected ? "tree-item-selected" : (isHighlighted ? "tree-item-highlighted" : ""))">
                <BodyContent Context="item">
                    <div class="d-flex align-center gap-2 flex-grow-1">
                        <MudText Typo="Typo.body2"
                                 Class="@(isSelected ? "font-weight-bold mud-primary-text" : "")">
                            @node?.Name
                        </MudText>
                        @if (node is { IsDirectory: false, Size: > 0 })
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary ml-auto">
                                @FormatFileSize(node.Size)
                            </MudText>
                        }
                        @if (isHighlighted && !isSelected)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Star"
                                     Size="Size.Small"
                                     Color="Color.Success"
                                     Class="ml-1"/>
                        }
                        @if (isSelected)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Size="Size.Small"
                                     Color="Color.Primary"
                                     Class="ml-1"/>
                        }
                    </div>
                </BodyContent>
            </MudTreeViewItem>
        </ItemTemplate>
    </MudTreeView>
}

@* 所有样式已迁移到 /css/components/file-explorer.css *@
