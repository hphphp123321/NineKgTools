<MudTextField T="string"
              Class="@Class"
              Value="@Value"
              ValueChanged="OnValueChanged"
              Typo="@Typo"
              Label="@Label"
              Variant="@Variant"
              InputType="@(_isPasswordVisible ? InputType.Text : InputType.Password)"
              Adornment="Adornment.End"
              HelperText="@HelperText"
              HelperTextOnFocus="true"
              AdornmentIcon="@(_isPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
              AdornmentColor="@AdornmentColor"
              OnAdornmentClick="TogglePasswordVisibility"
              AdornmentAriaLabel="@(_isPasswordVisible ? HideAdornmentAriaLabel : ShowAdornmentAriaLabel)"
              Disabled="@Disabled"
              Margin="@Margin"/>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public string Class { get; set; } = "";

    [Parameter] public Typo Typo { get; set; } = Typo.body1;

    [Parameter] public string Label { get; set; } = "密码";

    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;

    [Parameter] public string ShowAdornmentAriaLabel { get; set; } = "显示密码";
    [Parameter] public string HideAdornmentAriaLabel { get; set; } = "隐藏密码";

    [Parameter] public Color AdornmentColor { get; set; } = Color.Info;

    [Parameter] public string HelperText { get; set; } = "密码";

    [Parameter] public bool Disabled { get; set; } = false;

    [Parameter] public Margin Margin { get; set; } = Margin.None;

    private bool _isPasswordVisible;

    private Task OnValueChanged(string? value)
    {
        Value = value;
        return ValueChanged.InvokeAsync(value);
    }

    private void TogglePasswordVisibility() => _isPasswordVisible = !_isPasswordVisible;
}