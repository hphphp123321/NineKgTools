<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:NineKgTools.Desktop.ViewModels"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:anim="using:NineKgTools.Desktop.Animations"
        xmlns:components="using:NineKgTools.Desktop.Views.Components"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="900"
        x:Class="NineKgTools.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="NineKgTools"
        Icon="avares://NineKgTools.Desktop/Assets/Logos/logo-9-icon.png"
        Width="1280" Height="900"
        MinWidth="640" MinHeight="480"
        TransparencyLevelHint="Mica,AcrylicBlur,Blur"
        Background="Transparent">

    <Grid RowDefinitions="Auto,*">

        <!-- 自动更新提示条（Velopack 安装版静默检查命中后弹出）。
             IsClosable 的 X = "稍后"（本次会话隐藏，下次启动重查）；ActionButton = "立即更新"。 -->
        <ui:FAInfoBar Grid.Row="0"
                      IsOpen="{Binding UpdateAvailable, Mode=TwoWay}"
                      Severity="Informational"
                      IsClosable="True"
                      Title="发现新版本"
                      Message="{Binding UpdateVersionText, StringFormat='版本 {0} 可用，建议更新。'}">
            <ui:FAInfoBar.ActionButton>
                <Button Content="立即更新" Command="{Binding ApplyUpdateCommand}" />
            </ui:FAInfoBar.ActionButton>
        </ui:FAInfoBar>

        <ui:FANavigationView x:Name="NavView"
                       Grid.Row="1"
                       PaneDisplayMode="Auto"
                       CompactModeThresholdWidth="640"
                       ExpandedModeThresholdWidth="1008"
                       OpenPaneLength="240"
                       IsBackButtonVisible="False"
                       IsSettingsVisible="True"
                       PaneTitle="NineKgTools"
                       SelectionChanged="OnNavigationSelectionChanged">

        <!-- 侧栏底部全局搜索（§12 决策入口①）。Ctrl+K 快捷键由 Window.KeyBindings 触发聚焦本框。
             SearchBox.GotFocus → 弹 Flyout Popup 显示 4 类型实时预览；Up/Down/Enter/Esc/Ctrl+Enter 路由到 Flyout VM。 -->
        <ui:FANavigationView.PaneFooter>
            <Border Padding="12,8" x:Name="SearchFooter">
                <StackPanel Spacing="6">
                    <TextBlock Text="全局搜索" FontSize="11" Opacity="0.6" />
                    <TextBox x:Name="GlobalSearchBox"
                             Text="{Binding SearchFlyoutVm.Query, Mode=TwoWay}"
                             PlaceholderText="搜索媒体、标签、创作者、社团（Ctrl+K）"
                             GotFocus="OnSearchBoxGotFocus"
                             TextChanged="OnSearchBoxTextChanged"
                             KeyDown="OnSearchBoxKeyDown" />
                    <!-- 实时预览 Popup —— PlacementTarget=SearchBox / Right 弹 / LightDismiss 自动关 -->
                    <Popup x:Name="SearchFlyoutPopup"
                           PlacementTarget="{Binding #GlobalSearchBox}"
                           Placement="RightEdgeAlignedTop"
                           HorizontalOffset="8"
                           IsOpen="{Binding SearchFlyoutVm.IsOpen, Mode=TwoWay}"
                           IsLightDismissEnabled="True"
                           OverlayDismissEventPassThrough="False">
                        <components:GlobalSearchFlyout DataContext="{Binding SearchFlyoutVm}" />
                    </Popup>
                </StackPanel>
            </Border>
        </ui:FANavigationView.PaneFooter>

        <ui:FANavigationView.MenuItems>
            <ui:FANavigationViewItem Content="首页" Tag="HomeViewModel" IsSelected="True">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconHome}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="媒体库" Tag="MediaOverviewViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconLibrary}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="待处理" Tag="PendingMediaViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconInbox}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="媒体源" Tag="SourcesViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconFolderOpen}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="任务" Tag="BackgroundTasksViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconTasks}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItemSeparator />

            <ui:FANavigationViewItem Content="标签" Tag="TagsViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconTags}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="创作者" Tag="CreatorsViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconCreators}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="社团" Tag="CirclesViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconCreators}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="收藏夹" Tag="FavoritesViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconStar}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>

            <ui:FANavigationViewItem Content="网站" Tag="WebsitesViewModel">
                <ui:FANavigationViewItem.IconSource>
                    <ui:FAPathIconSource Data="{StaticResource IconWeb}" />
                </ui:FANavigationViewItem.IconSource>
            </ui:FANavigationViewItem>
        </ui:FANavigationView.MenuItems>

        <!-- 主内容区：ViewLocator 自动把 PageViewModelBase 渲染为对应 View
             用 TransitioningContentControl + FadeSlideUpTransition 给 view 切换加 160ms
             fade + 8px 上浮过渡（FA 全局动画已禁，这里独立提供桌面端规范的页面过渡）。 -->
        <TransitioningContentControl Content="{Binding CurrentPage}">
            <TransitioningContentControl.PageTransition>
                <anim:FadeSlideUpTransition Duration="0:0:0.2" SlideOffset="8" />
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>

    </ui:FANavigationView>

    <!-- 拖拽 Overlay：默认隐藏，DragEnter（停留 200ms 后）显示；跨两行覆盖整窗 -->
    <Border x:Name="DragOverlay"
            Grid.Row="0" Grid.RowSpan="2"
            IsVisible="False"
            IsHitTestVisible="False"
            Background="#80000000"
            CornerRadius="0">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
            </Transitions>
        </Border.Transitions>
        <Border MaxWidth="520" MaxHeight="280"
                Padding="36,32"
                CornerRadius="14"
                Background="{DynamicResource AcrylicInAppFillColorBaseBrush}"
                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="14" HorizontalAlignment="Center">
                <TextBlock Text="📥" FontSize="64"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="放下文件以识别"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="或文件夹以加入监视"
                           FontSize="13" Opacity="0.75"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Border>

    </Grid>

</Window>
