<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NineKgTools.Desktop.Views.Components.EditableAliasList"
             x:Name="Root">

    <StackPanel Spacing="6">
        <!-- chip 列表 -->
        <ItemsControl ItemsSource="{Binding #Root.Aliases}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Padding="10,4" Margin="0,0,6,6"
                            CornerRadius="12"
                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center" />
                            <Button IsVisible="{Binding #Root.IsEditable}"
                                    Click="OnRemoveClick"
                                    Tag="{Binding}"
                                    Width="18" Height="18"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ToolTip.Tip="移除">
                                <TextBlock Text="✕" FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 编辑模式：添加按钮 -->
        <Button IsVisible="{Binding #Root.IsEditable}"
                Click="OnAddClick"
                Padding="10,4"
                HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="+" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="添加别名" FontSize="12" />
            </StackPanel>
        </Button>

        <!-- 只读模式 + 列表为空：占位 -->
        <TextBlock IsVisible="{Binding #Root.ShowEmptyHint}"
                   Text="（暂无别名）"
                   FontSize="11" Opacity="0.55" />
    </StackPanel>

</UserControl>
