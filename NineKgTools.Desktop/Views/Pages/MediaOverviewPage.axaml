<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:conv="using:NineKgTools.Desktop.Converters"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.MediaOverviewPage"
             x:DataType="vm:MediaOverviewViewModel">

    <UserControl.Styles>
        <!-- 类别切换按钮：默认透明背景 + 1px 边框；切换时 220ms 平滑过渡 -->
        <Style Selector="Button.cat-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.22" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.22" Easing="CubicEaseOut" />
                    <ThicknessTransition Property="BorderThickness" Duration="0:0:0.22" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <!-- 底部 indicator 横条：默认 0 宽 + 透明，选中态展开 -->
        <Style Selector="Border.cat-indicator">
            <Setter Property="Height" Value="3" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="14,0,14,0" />
            <Setter Property="CornerRadius" Value="2,2,0,0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="scaleX(0.2)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.cat-indicator.active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scaleX(1.0)" />
        </Style>
        <!-- 选中态："全部"用系统 accent，5 类别用各自的签名色 + 同色 2px 边框 -->
        <Style Selector="Button.cat-tab.sel-all">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryAllFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryAllBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.cat-tab.sel-video">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryVideoFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryVideoBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.cat-tab.sel-audio">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryAudioFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryAudioBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.cat-tab.sel-game">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryGameFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryGameBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.cat-tab.sel-picture">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryPictureFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryPictureBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.cat-tab.sel-text">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryTextFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryTextBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- 选中态文字加粗 -->
        <Style Selector="Button.cat-tab.sel-all TextBlock,
                         Button.cat-tab.sel-video TextBlock,
                         Button.cat-tab.sel-audio TextBlock,
                         Button.cat-tab.sel-game TextBlock,
                         Button.cat-tab.sel-picture TextBlock,
                         Button.cat-tab.sel-text TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- ========== Row 0: 顶部细 ProgressBar（IsLoading 状态反馈，不影响布局） ==========
             之前 IsLoading 用 6 张骨架卡 WrapPanel 占位，但骨架的"自然高度 ~640px" vs 真实
             ScrollViewer "撑满 row 4" 切换时容器高度突变，加上滚动条出现/消失会让卡片 wrap
             重新计算——视觉上"上下抖一下"。改成顶部 4px indeterminate 横条：
             - Loading 中：显示 → 用户看到正在加载
             - 不影响 row 4 主区高度（ProgressBar 自己 row=0，row 4 = * 占满 仍稳定） -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,0"
                     Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                     Background="Transparent"
                     BorderThickness="0" />

        <!-- ========== Row 1: 分类切换栏（"全部" + 5 类别 = 6 列） ========== -->
        <Grid Grid.Row="1" Margin="32,21,32,12"
              ColumnDefinitions="*,12,*,12,*,12,*,12,*,12,*">

            <Grid Grid.Column="0">
                <Button Classes="cat-tab"
                        Classes.sel-all="{Binding IsCategoryAll}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="All"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconLibrary}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryAllBrush}" />
                        <TextBlock Text="全部" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryAllBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryAll}"
                        Background="{DynamicResource BrandCategoryAllBrush}" />
            </Grid>

            <Grid Grid.Column="2">
                <Button Classes="cat-tab"
                        Classes.sel-video="{Binding IsCategoryVideo}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="Video"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconCategoryVideo}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryVideoBrush}" />
                        <TextBlock Text="视频" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryVideoBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryVideo}"
                        Background="{DynamicResource BrandCategoryVideoBrush}" />
            </Grid>

            <Grid Grid.Column="4">
                <Button Classes="cat-tab"
                        Classes.sel-audio="{Binding IsCategoryAudio}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="Audio"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconCategoryAudio}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryAudioBrush}" />
                        <TextBlock Text="音频" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryAudioBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryAudio}"
                        Background="{DynamicResource BrandCategoryAudioBrush}" />
            </Grid>

            <Grid Grid.Column="6">
                <Button Classes="cat-tab"
                        Classes.sel-game="{Binding IsCategoryGame}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="Game"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconCategoryGame}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryGameBrush}" />
                        <TextBlock Text="游戏" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryGameBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryGame}"
                        Background="{DynamicResource BrandCategoryGameBrush}" />
            </Grid>

            <Grid Grid.Column="8">
                <Button Classes="cat-tab"
                        Classes.sel-picture="{Binding IsCategoryPicture}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="Picture"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconCategoryPicture}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryPictureBrush}" />
                        <TextBlock Text="图片" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryPictureBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryPicture}"
                        Background="{DynamicResource BrandCategoryPictureBrush}" />
            </Grid>

            <Grid Grid.Column="10">
                <Button Classes="cat-tab"
                        Classes.sel-text="{Binding IsCategoryText}"
                        Command="{Binding SelectCategoryCommand}" CommandParameter="Text"
                        HorizontalAlignment="Stretch" Padding="14,12">
                    <StackPanel Spacing="8">
                        <PathIcon Data="{StaticResource IconCategoryText}" Width="22" Height="22"
                                  Foreground="{DynamicResource BrandCategoryTextBrush}" />
                        <TextBlock Text="文本" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandCategoryTextBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Border Classes="cat-indicator" Classes.active="{Binding IsCategoryText}"
                        Background="{DynamicResource BrandCategoryTextBrush}" />
            </Grid>

        </Grid>

        <!-- ========== Row 2: 筛选 / 排序 / 新建 ========== -->
        <Grid Grid.Row="2" Margin="32,12,32,8"
              ColumnDefinitions="Auto,12,*,12,Auto,12,Auto,12,Auto">
            <!-- 筛选按钮：HasActiveFilter 时变 accent 色 -->
            <Button Grid.Column="0"
                    Command="{Binding OpenFilterCommand}"
                    ToolTip.Tip="多维筛选（分类 / 标签 / 收藏 / 评分 / 日期）">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconFilter}" Width="14" Height="14" />
                    <TextBlock Text="筛选" />
                    <Border IsVisible="{Binding HasActiveFilter}"
                            Width="8" Height="8"
                            CornerRadius="4"
                            Background="{DynamicResource SystemFillColorAttentionBrush}"
                            VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <TextBox Grid.Column="2"
                     PlaceholderText="搜索标题..."
                     Text="{Binding SearchText, Mode=TwoWay}" />

            <ComboBox Grid.Column="4"
                      ItemsSource="{Binding AvailableSorts}"
                      SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                      MinWidth="140">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SortChoice">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- 新建：主按钮触发 flyout，内含"文件夹 / 文件"两选项 -->
            <Button Grid.Column="6"
                    ToolTip.Tip="手动添加媒体（指定文件或文件夹路径）">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="+ 新建" FontWeight="SemiBold" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="新建（文件夹）"
                                  Command="{Binding NewMediaFromFolderCommand}" />
                        <MenuItem Header="新建（文件）"
                                  Command="{Binding NewMediaFromFileCommand}" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <Button Grid.Column="8" Command="{Binding LoadCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="14" Height="14" />
                    <TextBlock Text="刷新" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ========== Row 3: 已应用筛选状态条（仅 HasActiveFilter 显示） ========== -->
        <Border Grid.Row="3" Margin="32,0,32,12"
                IsVisible="{Binding HasActiveFilter}"
                Padding="12,6"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="0"
                           Text="{Binding FilterSummary}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1"
                        Command="{Binding ClearFilterCommand}"
                        Padding="10,4"
                        Content="清除筛选" />
            </Grid>
        </Border>

        <!-- ========== Row 4: 主内容（卡片网格 / 空 / 错误三态） ==========
             不再用 IsLoading 骨架卡——Loading 反馈走 row 0 的顶部 ProgressBar 横条，
             避免"骨架占位 vs 真实卡组"切换时容器高度突变（之前的"上下抖动"根因）。 -->
        <Grid Grid.Row="4" Margin="32,0,32,0">

            <!-- 加载中骨架（已删，留 placeholder 防误删此 region） -->
            <WrapPanel IsVisible="False">
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
                <Border Width="180" Height="320" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" Margin="0,0,12,12" />
            </WrapPanel>

            <!-- 空状态卡 -->
            <Border IsVisible="{Binding ShowEmpty}"
                    Background="{DynamicResource LayerFillColorAltBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="48,40"
                    Margin="0,16"
                    MaxWidth="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <PathIcon Data="{StaticResource IconLibrary}" Width="72" Height="72"
                              Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                              Opacity="0.6" HorizontalAlignment="Center" />
                    <TextBlock Text="该分类暂无媒体"
                               HorizontalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="去媒体源页面添加监视文件夹，识别后入库的媒体会出现在这里。"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Opacity="0.7"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 错误状态 -->
            <StackPanel IsVisible="{Binding ShowError}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" MaxWidth="320">
                <PathIcon Data="{StaticResource IconInbox}" Width="56" Height="56"
                          Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{Binding LoadError}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <Button Command="{Binding LoadCommand}"
                        HorizontalAlignment="Center"
                        Content="重试" />
            </StackPanel>

            <!-- 卡片网格（fade-items：分类切换时 children 重建，每张卡 attach 时跑 200ms opacity 渐入） -->
            <ScrollViewer IsVisible="{Binding HasItems}">
                <ItemsControl ItemsSource="{Binding Items}" Classes="fade-items">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaCardViewModel">
                            <!-- Button 包裹整张卡 → 整卡可点击；Padding/Background 清零让 Button 视觉等于内层 Border -->
                            <Button Command="{Binding OpenDetailCommand}"
                                    Padding="0" Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Margin="0,0,12,12"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                            <Border Width="180" Height="320"
                                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <Grid RowDefinitions="*,Auto">
                                    <Grid Grid.Row="0" Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                        <Image Source="{Binding Cover}"
                                               Stretch="UniformToFill"
                                               IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Border IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}"
                                                Background="{Binding TopCategory, Converter={x:Static conv:CategoryFillBrushConverter.Instance}}">
                                            <PathIcon Data="{Binding CategoryIcon}"
                                                      Width="48" Height="48"
                                                      Foreground="{Binding CategoryBrush}"
                                                      Opacity="0.6"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Border Grid.Row="1" Padding="10,8">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Title}" />
                                            <TextBlock Text="{Binding CircleName}"
                                                       FontSize="11"
                                                       Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding CircleName, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            <TextBlock Text="{Binding RatingText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                       IsVisible="{Binding HasRating}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- ========== Row 5: 分页栏 ========== -->
        <Border Grid.Row="5" Padding="32,12"
                Background="{DynamicResource LayerFillColorAltBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                IsVisible="{Binding HasItems}">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Opacity="0.7">
                    <Run Text="共" />
                    <Run Text="{Binding TotalCount}" />
                    <Run Text="条 ·" />
                    <Run Text="第" />
                    <Run Text="{Binding PageNumber}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalPages}" />
                    <Run Text="页" />
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Command="{Binding PrevPageCommand}" Content="上一页" />
                    <Button Command="{Binding NextPageCommand}" Content="下一页" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>

</UserControl>
