<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.WebsitesPage"
             x:DataType="vm:WebsitesViewModel">
    <StackPanel Margin="32,24,32,32" Spacing="16">
        <TextBlock Text="网站" Theme="{StaticResource TitleLargeTextBlockStyle}" />
        <ui:InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="Phase 2.2 待实现"
                    Message="DLsite / Bangumi / Steam 卡片 + 5 Tab 拖拽优先级 + 测试连接。" />
    </StackPanel>
</UserControl>
