<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.WebsitesPage"
             x:DataType="vm:WebsitesViewModel">

    <UserControl.Styles>
        <!-- 网站卡 -->
        <Style Selector="Border.site-card">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <!-- 状态点 -->
        <Style Selector="Ellipse.status-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>
        <Style Selector="Ellipse.status-dot.on">
            <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
        </Style>
        <Style Selector="Ellipse.status-dot.off">
            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>
        <!-- 字段 label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 头部 -->
        <Grid Grid.Row="0" Margin="32,24,32,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="识别网站" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="配置 DLsite / Bangumi / Steam 三大识别源 · 凭证修改后立即生效"
                           Opacity="0.7" FontSize="13" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="{Binding SaveStatusText}"
                       Opacity="0.6" FontSize="12"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- 主滚动区 -->
        <ScrollViewer Grid.Row="1" Padding="32,8,32,24">
            <StackPanel Spacing="16">

                <!-- ==================== DLsite ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="{DynamicResource BrandCategoryPictureFillBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="DL" FontWeight="Bold" FontSize="16"
                                           Foreground="{DynamicResource BrandCategoryPictureBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="DLsite" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding DLsiteEnable}"
                                             Classes.off="{Binding !DLsiteEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="日本同人音声 / 漫画 / 游戏 · 无需认证" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding DLsiteEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="使用 Selenium 抓取评分"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="需要本机安装 Chromium · Docker 部署不可用 · 仅获取评分时使用"
                                           FontSize="11" Opacity="0.65" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding DLsiteUseSelenium, Mode=TwoWay}"
                                          OnContent="开"
                                          OffContent="关"
                                          IsEnabled="{Binding DLsiteEnable}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== Bangumi ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="{DynamicResource BrandCategoryVideoFillBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="bgm" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource BrandCategoryVideoBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Bangumi" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding BangumiEnable}"
                                             Classes.off="{Binding !BangumiEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="番组计划 · 动画/书籍/游戏 · 需 ApiKey" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding BangumiEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <StackPanel Spacing="6" IsEnabled="{Binding BangumiEnable}">
                            <TextBlock Text="API Key" Classes="field-label" />
                            <TextBox Text="{Binding BangumiApiKey, Mode=TwoWay}"
                                     Watermark="粘贴 Bangumi 个人 ApiKey..."
                                     PasswordChar="●" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding BangumiApiKeyMasked}"
                                           FontSize="11" Opacity="0.65"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Command="{Binding OpenBangumiApiKeyPageCommand}"
                                        Padding="10,4"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="去申请 ApiKey →" FontSize="12" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== Steam ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="{DynamicResource BrandCategoryGameFillBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="STM" FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource BrandCategoryGameBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Steam" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding SteamEnable}"
                                             Classes.off="{Binding !SteamEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="Storefront · 游戏识别 · 公开 API 限流 200/5min" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding SteamEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <Grid ColumnDefinitions="*,16,*" IsEnabled="{Binding SteamEnable}">

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="语言（影响 name / description 本地化）" Classes="field-label" />
                                <ComboBox ItemsSource="{Binding SteamLanguages}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding SteamLanguage, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SteamLanguageOption">
                                            <TextBlock Text="{Binding Display}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="国家（影响价格 / 发行区域）" Classes="field-label" />
                                <ComboBox ItemsSource="{Binding SteamCountries}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding SteamCountryCode, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SteamCountryOption">
                                            <TextBlock Text="{Binding Display}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="⚠ 中国大陆 (CN) 已禁用 — 部分游戏对 CN 区屏蔽，会导致识别失败"
                                           FontSize="11" Opacity="0.7"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== 优先级配置占位（Phase 2.2 后续） ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="识别优先级" FontSize="14" FontWeight="SemiBold" />
                        <ui:InfoBar Severity="Informational"
                                    IsOpen="True"
                                    IsClosable="False"
                                    Title="拖拽优先级配置（即将到来）"
                                    Message="按 5 个媒体分类分别配置 DLsite/Bangumi/Steam 的识别优先级，需要 Avalonia DragDrop 实现。当前先编辑 config.yaml 的 website.priority 节点生效。" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
