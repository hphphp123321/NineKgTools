<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.WebsitesPage"
             x:DataType="vm:WebsitesViewModel">

    <UserControl.Styles>
        <!-- 网站卡 -->
        <Style Selector="Border.site-card">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <!-- 状态点 -->
        <Style Selector="Ellipse.status-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>
        <Style Selector="Ellipse.status-dot.on">
            <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
        </Style>
        <Style Selector="Ellipse.status-dot.off">
            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>
        <!-- 字段 label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- 优先级行 hover 提亮 -->
        <Style Selector="Border.priority-row">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.priority-row:pointerover">
            <Setter Property="Background" Value="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}" />
        </Style>

        <!-- chip Border 默认带 RenderTransformOrigin，避免拖拽 scale 时偏移 -->
        <Style Selector="Border.priority-chip">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>

        <!-- drop indicator：拖拽时显示的 accent 竖线，IsHitTestVisible=False 不挡光标 -->
        <Style Selector="Border.drop-indicator">
            <Setter Property="Width" Value="3" />
            <Setter Property="CornerRadius" Value="1.5" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.13" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.drop-indicator.active">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- chip hover 抬升 + 显示 ✕ -->
        <Style Selector="Grid.priority-chip-host Button.chip-remove">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid.priority-chip-host:pointerover Button.chip-remove">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <!-- Flyout 可添加项：默认浅 accent bg + accent border，hover 加深 -->
        <Style Selector="Button.addable-site">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.addable-site:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 头部 -->
        <Grid Grid.Row="0" Margin="32,24,32,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="识别网站" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="配置 DLsite / Bangumi / Steam 三大识别源 · 凭证修改后立即生效"
                           Opacity="0.7" FontSize="13" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="{Binding SaveStatusText}"
                       Opacity="0.6" FontSize="12"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- 主滚动区 -->
        <ScrollViewer Grid.Row="1" Padding="32,8,32,24">
            <StackPanel Spacing="16">

                <!-- ==================== DLsite ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="White"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True">
                                <Image Source="avares://NineKgTools.Desktop/Assets/Logos/logo-dlsite.png"
                                       Stretch="Uniform"
                                       Margin="4" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="DLsite" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding DLsiteEnable}"
                                             Classes.off="{Binding !DLsiteEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="日本同人音声 / 漫画 / 游戏 · 无需认证" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding DLsiteEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="使用 Selenium 抓取评分"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="需要本机安装 Chromium · Docker 部署不可用 · 仅获取评分时使用"
                                           FontSize="11" Opacity="0.65" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding DLsiteUseSelenium, Mode=TwoWay}"
                                          OnContent="开"
                                          OffContent="关"
                                          IsEnabled="{Binding DLsiteEnable}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== Bangumi ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="White"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True">
                                <Image Source="avares://NineKgTools.Desktop/Assets/Logos/logo-bangumi.png"
                                       Stretch="Uniform"
                                       Margin="4" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Bangumi" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding BangumiEnable}"
                                             Classes.off="{Binding !BangumiEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="番组计划 · 动画/书籍/游戏 · 需 ApiKey" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding BangumiEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <StackPanel Spacing="6" IsEnabled="{Binding BangumiEnable}">
                            <TextBlock Text="API Key" Classes="field-label" />
                            <TextBox Text="{Binding BangumiApiKey, Mode=TwoWay}"
                                     PlaceholderText="粘贴 Bangumi 个人 ApiKey..."
                                     PasswordChar="●" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding BangumiApiKeyMasked}"
                                           FontSize="11" Opacity="0.65"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Command="{Binding OpenBangumiApiKeyPageCommand}"
                                        Padding="10,4"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="去申请 ApiKey →" FontSize="12" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== Steam ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,12,*,Auto">
                            <Border Grid.Column="0" Width="44" Height="44"
                                    CornerRadius="10"
                                    Background="{DynamicResource BrandCategoryGameFillBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="STM" FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource BrandCategoryGameBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Steam" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Classes="status-dot"
                                             Classes.on="{Binding SteamEnable}"
                                             Classes.off="{Binding !SteamEnable}"
                                             VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                               Text="Storefront · 游戏识别 · 公开 API 限流 200/5min" />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="3"
                                          IsChecked="{Binding SteamEnable, Mode=TwoWay}"
                                          OnContent="启用"
                                          OffContent="禁用"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <Grid ColumnDefinitions="*,16,*" IsEnabled="{Binding SteamEnable}">

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="语言（影响 name / description 本地化）" Classes="field-label" />
                                <ComboBox ItemsSource="{Binding SteamLanguages}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding SteamLanguage, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SteamLanguageOption">
                                            <TextBlock Text="{Binding Display}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="国家（影响价格 / 发行区域）" Classes="field-label" />
                                <ComboBox ItemsSource="{Binding SteamCountries}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding SteamCountryCode, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SteamCountryOption">
                                            <TextBlock Text="{Binding Display}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="⚠ 中国大陆 (CN) 已禁用 — 部分游戏对 CN 区屏蔽，会导致识别失败"
                                           FontSize="11" Opacity="0.7"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== 识别优先级（6 行全开，与 Web 对齐） ==================== -->
                <Border Classes="site-card">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="识别优先级" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="按媒体类型分别配置识别源顺序 · 靠前的优先使用 · 修改自动保存"
                                       FontSize="11" Opacity="0.65" />
                        </StackPanel>

                        <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}" Height="1" />

                        <ItemsControl ItemsSource="{Binding PriorityRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PriorityRowViewModel">
                                    <Border Classes="priority-row"
                                            Padding="14,12"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            Background="{DynamicResource LayerFillColorAltBrush}">
                                        <Grid ColumnDefinitions="Auto,10,Auto,8,Auto,16,*,8,Auto">
                                            <!-- 左侧 accent 色条 + 图标 + 分类名 -->
                                            <Border Grid.Column="0"
                                                    Width="3"
                                                    VerticalAlignment="Stretch"
                                                    CornerRadius="2"
                                                    Background="{Binding AccentBrush}" />
                                            <PathIcon Grid.Column="2"
                                                      Data="{Binding IconGeometry}"
                                                      Width="18" Height="18"
                                                      Foreground="{Binding AccentBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       MinWidth="32" />
                                            <!-- chip 行 + drop indicator overlay -->
                                            <Grid Grid.Column="6"
                                                  Tag="ChipsContainer"
                                                  VerticalAlignment="Center">
                                                <ItemsControl Classes="chips-list"
                                                              VerticalAlignment="Center"
                                                              ItemsSource="{Binding Chips}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PriorityChipViewModel">
                                                            <!-- Margin top=8 给浮出的 ✕ 留出血空间，避免被 WrapPanel 行高裁切 -->
                                                            <Grid Classes="priority-chip-host" Margin="0,8,6,2">
                                                                <Border Classes="priority-chip"
                                                                        Background="{Binding Row.FillBrush}"
                                                                        BorderBrush="{Binding Row.AccentBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="14"
                                                                        Padding="12,5,12,5"
                                                                        Cursor="SizeAll"
                                                                        PointerPressed="OnChipPointerPressed"
                                                                        ToolTip.Tip="按住拖拽以重排">
                                                                    <TextBlock Text="{Binding SiteName}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding Row.AccentBrush}"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <!-- hover ✕ 移除按钮 -->
                                                                <Button Classes="chip-remove"
                                                                        Command="{Binding RemoveCommand}"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Margin="0,-6,-6,0"
                                                                        Width="18" Height="18"
                                                                        Padding="0"
                                                                        CornerRadius="9"
                                                                        Background="{DynamicResource SystemFillColorCriticalBrush}"
                                                                        Foreground="White"
                                                                        BorderThickness="0"
                                                                        ToolTip.Tip="从此分类移除">
                                                                    <TextBlock Text="✕" FontSize="10" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- 拖拽 drop indicator——code-behind 控制 RenderTransform / Classes.active -->
                                                <Border Classes="drop-indicator"
                                                        Name="DropIndicator"
                                                        Height="22"
                                                        Background="{Binding AccentBrush}" />
                                            </Grid>

                                            <!-- 空状态文案 -->
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding EmptyHint}"
                                                       FontSize="12"
                                                       FontStyle="Italic"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsEmpty}" />

                                            <!-- + 添加 按钮（Flyout） -->
                                            <Button Grid.Column="8"
                                                    Padding="10,4"
                                                    Background="Transparent"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{Binding AccentBrush}"
                                                    CornerRadius="14"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="添加识别源到此分类">
                                                <StackPanel Orientation="Horizontal" Spacing="3">
                                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="添加" FontSize="12"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Button.Flyout>
                                                    <Flyout Placement="BottomEdgeAlignedRight">
                                                        <StackPanel MinWidth="280" MaxWidth="340" Spacing="0">
                                                            <!-- Header：添加识别源到「分类名」 -->
                                                            <TextBlock Text="{Binding FlyoutHeader}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{Binding AccentBrush}"
                                                                       Margin="4,2,4,8" />

                                                            <!-- ============ 可添加 section ============ -->
                                                            <StackPanel Spacing="4" IsVisible="{Binding HasAddable}">
                                                                <TextBlock Text="可添加"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Opacity="0.55"
                                                                           Margin="4,0,4,2"
                                                                           Classes="section-label" />
                                                                <ItemsControl ItemsSource="{Binding AddableSites}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Spacing="4" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:AddableSiteOption">
                                                                            <Button Classes="addable-site"
                                                                                    HorizontalAlignment="Stretch"
                                                                                    HorizontalContentAlignment="Stretch"
                                                                                    Padding="12,10"
                                                                                    Command="{Binding $parent[ItemsControl].((vm:PriorityRowViewModel)DataContext).AddSiteCommand}"
                                                                                    CommandParameter="{Binding Name}">
                                                                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                   FontSize="14" FontWeight="SemiBold" />
                                                                                        <TextBlock Text="{Binding UnavailableReason}"
                                                                                                   FontSize="11"
                                                                                                   Opacity="0.6" />
                                                                                    </StackPanel>
                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="+"
                                                                                               FontSize="20" FontWeight="Bold"
                                                                                               Foreground="{Binding $parent[ItemsControl].((vm:PriorityRowViewModel)DataContext).AccentBrush}"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Margin="8,0,4,0" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>

                                                            <!-- ============ empty state（无可添加） ============ -->
                                                            <Border IsVisible="{Binding !HasAddable}"
                                                                    Padding="14,16"
                                                                    Margin="0,4,0,4"
                                                                    CornerRadius="6"
                                                                    Background="{DynamicResource LayerFillColorAltBrush}">
                                                                <StackPanel Orientation="Horizontal" Spacing="10"
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="✓"
                                                                               FontSize="16" FontWeight="Bold"
                                                                               Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                                               IsVisible="{Binding !EmptyFlyoutIsWarning}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="⚠"
                                                                               FontSize="16"
                                                                               Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                               IsVisible="{Binding EmptyFlyoutIsWarning}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding EmptyFlyoutMessage}"
                                                                               FontSize="12"
                                                                               Opacity="0.85"
                                                                               TextWrapping="Wrap"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- 分隔线（仅当两段都存在时显示） -->
                                                            <Border Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                    Height="1" Margin="0,10,0,8"
                                                                    IsVisible="{Binding HasOthers}" />

                                                            <!-- ============ 其他 section（紧凑） ============ -->
                                                            <StackPanel Spacing="2" IsVisible="{Binding HasOthers}">
                                                                <TextBlock Text="其他"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Opacity="0.55"
                                                                           Margin="4,0,4,2" />
                                                                <ItemsControl ItemsSource="{Binding OtherSites}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Spacing="0" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:AddableSiteOption">
                                                                            <Grid ColumnDefinitions="Auto,8,Auto,8,*"
                                                                                  Margin="4,3"
                                                                                  Opacity="0.55">
                                                                                <!-- ✓ 已添加 / ⊘ 不兼容 -->
                                                                                <TextBlock Grid.Column="0"
                                                                                           Text="✓"
                                                                                           FontSize="11"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                                                           VerticalAlignment="Center"
                                                                                           IsVisible="{Binding UnavailableReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                                <TextBlock Grid.Column="2"
                                                                                           Text="{Binding Name}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center" />
                                                                                <TextBlock Grid.Column="4"
                                                                                           Text="{Binding UnavailableReason}"
                                                                                           FontSize="11"
                                                                                           Opacity="0.85"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           TextAlignment="Right"
                                                                                           VerticalAlignment="Center" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
