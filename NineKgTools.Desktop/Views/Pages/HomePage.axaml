<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel">

    <UserControl.Styles>
        <Style Selector="Border.stat-card">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.stat-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="RenderTransform" Value="translateY(-2px)" />
        </Style>

        <Style Selector="Button.stat-card">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.stat-card:pointerover">
            <Setter Property="RenderTransform" Value="translateY(-2px)" />
        </Style>

        <Style Selector="Border.cat-card">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.cat-card:pointerover">
            <Setter Property="RenderTransform" Value="translateY(-2px) scale(1.02)" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="32,24,32,32" Spacing="28">

            <!-- ========== 标题区 ========== -->
            <Border Padding="32,28"
                    CornerRadius="{StaticResource BrandLargeCornerRadius}"
                    Background="{DynamicResource BrandHeroGradient}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="首页"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="欢迎回来，下面是你的库概览。"
                                   Theme="{StaticResource BodyTextBlockStyle}"
                                   Opacity="0.75" />
                    </StackPanel>
                    <!-- 待处理快捷入口（如有） -->
                    <Border Grid.Column="1"
                            IsVisible="{Binding HasPending}"
                            Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                            BorderBrush="{DynamicResource SystemFillColorAttentionBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14,8"
                            VerticalAlignment="Center">
                        <Button Command="{Binding GoToPendingCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📥" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PendingText}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="→" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== 统计卡片栏 1 行：4 项实体计数（可点击跳转对应页） ========== -->
            <Grid ColumnDefinitions="*,12,*,12,*,12,*,12,*">
                <Button Grid.Column="0" Classes="stat-card" Command="{Binding GoToMediaLibraryCommand}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconLibrary}" Width="16" Height="16"
                                      Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                            <TextBlock Text="媒体" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding MediaCount}"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TotalSizeText}"
                                   Opacity="0.6" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Classes="stat-card" Command="{Binding GoToCreatorsCommand}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconCreators}" Width="16" Height="16"
                                      Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                            <TextBlock Text="创作者" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding CreatorCount}"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="点击进入" Opacity="0.45" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Classes="stat-card" Command="{Binding GoToCirclesCommand}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconCreators}" Width="16" Height="16"
                                      Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                            <TextBlock Text="社团" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding CircleCount}"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="点击进入" Opacity="0.45" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="6" Classes="stat-card" Command="{Binding GoToTagsCommand}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconTags}" Width="16" Height="16"
                                      Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                            <TextBlock Text="标签" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding TagCount}"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="点击进入" Opacity="0.45" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="8" Classes="stat-card" Command="{Binding GoToFavoritesCommand}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"
                                      Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                            <TextBlock Text="收藏夹" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding FavoriteCount}"
                                   Theme="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="点击进入" Opacity="0.45" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ========== 统计卡片栏 2 行：实时桌面状态 ========== -->
            <Grid ColumnDefinitions="*,16,*,16,*">
                <Border Grid.Column="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconFolderOpen}" Width="18" Height="18"
                                      Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                            <TextBlock Text="监视文件夹" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding WatchFolderActive}"
                                   Theme="{StaticResource DisplayTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WatchFolderText}" Opacity="0.5" FontSize="12" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconTasks}" Width="18" Height="18"
                                      Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                            <TextBlock Text="运行中任务" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding RunningTaskCount}"
                                   Theme="{StaticResource DisplayTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding RunningTaskText}" Opacity="0.5" FontSize="12" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconInbox}" Width="18" Height="18"
                                      Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                            <TextBlock Text="失败任务" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding FailedTaskCount}"
                                   Theme="{StaticResource DisplayTextBlockStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding FailedTaskText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                   IsVisible="{Binding HasFailedTasks}" />
                        <TextBlock Text="{Binding FailedTaskText}"
                                   FontSize="12" Opacity="0.5"
                                   IsVisible="{Binding !HasFailedTasks}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ========== 媒体类型分类排行（含计数） ========== -->
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="媒体类型分布"
                               Theme="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold" />
                    <Button Command="{Binding GoToTasksCommand}"
                            Padding="10,4"
                            Background="Transparent"
                            VerticalAlignment="Center">
                        <TextBlock Text="任务监控 →" FontSize="12"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                    </Button>
                </StackPanel>

                <Grid ColumnDefinitions="*,12,*,12,*,12,*,12,*">

                    <Border Grid.Column="0" Classes="cat-card"
                            Background="{DynamicResource BrandCategoryVideoFillBrush}"
                            BorderBrush="{DynamicResource BrandCategoryVideoBrush}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconCategoryVideo}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrandCategoryVideoBrush}" />
                            <TextBlock Text="视频" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryVideoBrush}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding VideoCount}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryVideoBrush}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Classes="cat-card"
                            Background="{DynamicResource BrandCategoryAudioFillBrush}"
                            BorderBrush="{DynamicResource BrandCategoryAudioBrush}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconCategoryAudio}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrandCategoryAudioBrush}" />
                            <TextBlock Text="音频" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryAudioBrush}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding AudioCount}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryAudioBrush}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Classes="cat-card"
                            Background="{DynamicResource BrandCategoryGameFillBrush}"
                            BorderBrush="{DynamicResource BrandCategoryGameBrush}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconCategoryGame}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrandCategoryGameBrush}" />
                            <TextBlock Text="游戏" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryGameBrush}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding GameCount}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryGameBrush}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Classes="cat-card"
                            Background="{DynamicResource BrandCategoryPictureFillBrush}"
                            BorderBrush="{DynamicResource BrandCategoryPictureBrush}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconCategoryPicture}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrandCategoryPictureBrush}" />
                            <TextBlock Text="图片" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryPictureBrush}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding PictureCount}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryPictureBrush}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="8" Classes="cat-card"
                            Background="{DynamicResource BrandCategoryTextFillBrush}"
                            BorderBrush="{DynamicResource BrandCategoryTextBrush}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconCategoryText}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrandCategoryTextBrush}" />
                            <TextBlock Text="文本" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryTextBrush}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding TextCount}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandCategoryTextBrush}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
