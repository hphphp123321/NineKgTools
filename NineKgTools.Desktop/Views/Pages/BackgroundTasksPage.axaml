<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.BackgroundTasksPage"
             x:DataType="vm:BackgroundTasksViewModel"
             x:Name="PageRoot">

    <UserControl.Styles>
        <!-- ===== 状态过滤 chip ===== -->
        <Style Selector="Button.filter-chip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.22" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.22" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.filter-chip.sel-all">
            <Setter Property="Background" Value="{DynamicResource BrandCategoryAllFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandCategoryAllBrush}" />
        </Style>
        <Style Selector="Button.filter-chip.sel-running">
            <Setter Property="Background" Value="{DynamicResource BrandStatusRunningFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorAttentionBrush}" />
        </Style>
        <Style Selector="Button.filter-chip.sel-succeeded">
            <Setter Property="Background" Value="{DynamicResource BrandStatusSuccessFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorSuccessBrush}" />
        </Style>
        <Style Selector="Button.filter-chip.sel-failed">
            <Setter Property="Background" Value="{DynamicResource BrandStatusFailedFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>
        <Style Selector="Button.filter-chip.sel-all TextBlock,
                         Button.filter-chip.sel-running TextBlock,
                         Button.filter-chip.sel-succeeded TextBlock,
                         Button.filter-chip.sel-failed TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- chip 底部 indicator 横条 -->
        <Style Selector="Border.chip-indicator">
            <Setter Property="Height" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="14,0,14,0" />
            <Setter Property="CornerRadius" Value="2,2,0,0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="scaleX(0.2)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.chip-indicator.active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scaleX(1.0)" />
        </Style>

        <!-- ===== 头部 live chip（有运行中任务时的脉动徽标） ===== -->
        <Style Selector="Border.live-chip">
            <Setter Property="Background" Value="{DynamicResource BrandStatusRunningFillBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="11,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Ellipse.live-dot">
            <Style.Animations>
                <Animation Duration="0:0:1.4" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.35" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- ===== 过滤 chip 内的计数 badge ===== -->
        <Style Selector="Border.count-badge">
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.count-badge TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <!-- ===== 任务行卡片（运行中 / 历史 / 定时 三 Tab 共用） ===== -->
        <Style Selector="Border.task-row">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,13" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.task-row:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="RenderTransform" Value="translateY(-1px)" />
        </Style>

        <!-- ===== 状态徽（圆角方块 tile，同待处理页分类 tile 语言） ===== -->
        <Style Selector="Border.status-dot">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.status-dot.running">
            <Setter Property="Background" Value="{DynamicResource BrandStatusRunningFillBrush}" />
            <!-- 运行中：徽标轻微"呼吸"，提示任务存活 -->
            <Style.Animations>
                <Animation Duration="0:0:1.7" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.62" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.status-dot.done">
            <Setter Property="Background" Value="{DynamicResource BrandStatusSuccessFillBrush}" />
        </Style>
        <Style Selector="Border.status-dot.failed">
            <Setter Property="Background" Value="{DynamicResource BrandStatusFailedFillBrush}" />
        </Style>

        <!-- ===== 任务标题 ===== -->
        <Style Selector="TextBlock.task-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ===== 卡内"子任务"展开区 ===== -->
        <Style Selector="Button.subtask-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.subtask-toggle PathIcon.chevron">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Opacity" Value="0.65" />
            <Setter Property="RenderTransform" Value="rotate(0deg)" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.subtask-toggle PathIcon.chevron.expanded">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>
        <!-- 子任务托盘：轻底色内嵌面板（无边框，非嵌套卡片） -->
        <Style Selector="Border.subtask-tray">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorAltBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <!-- 子任务行内的小号状态 tile -->
        <Style Selector="Border.status-dot.mini">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== 行操作图标按钮（32×32 ghost，任何宽度都放得下） ===== -->
        <Style Selector="Button.icon-action">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.icon-action PathIcon">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.icon-action:pointerover PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style Selector="Button.icon-action.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
        </Style>
        <Style Selector="Button.icon-action.danger:pointerover PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>

        <!-- ===== 细进度条 ===== -->
        <Style Selector="ProgressBar.slim">
            <Setter Property="MinHeight" Value="5" />
            <Setter Property="Height" Value="5" />
        </Style>

        <!-- ===== 类型角标 ===== -->
        <Style Selector="Border.type-badge">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.type-badge TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ========== Row 0: 头部 ========== -->
        <Grid Grid.Row="0" Margin="32,24,32,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="后台任务" FontSize="28" FontWeight="SemiBold" />
                    <!-- 有任务在跑时的 live 徽标：脉动小圆点 + 计数 -->
                    <Border Classes="live-chip" IsVisible="{Binding HasRunningTasks}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Classes="live-dot" Width="7" Height="7"
                                     Fill="{DynamicResource SystemFillColorAttentionBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                       FontWeight="SemiBold">
                                <Run Text="{Binding RunningCount}" /><Run Text=" 个运行中" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="实时跟进识别 / 监控 / 定时任务的执行状态"
                           Opacity="0.7" FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding ClearCompletedCommand}"
                    VerticalAlignment="Center"
                    IsVisible="{Binding SelectedTabIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconBroom}" Width="14" Height="14" />
                    <TextBlock Text="清理已完成" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ========== Row 1: 3-Tab 容器（运行中 / 历史 / 定时） ========== -->
        <TabControl Grid.Row="1"
                    Margin="32,0,32,16"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- ============== Tab 0: 运行中 ============== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconPlayCircle}" Width="14" Height="14" />
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="运行中 (" /><Run Text="{Binding AllCount}" /><Run Text=")" />
                        </TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">

                    <!-- 状态过滤 chip group -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,12,0,16">
                        <Grid>
                            <Button Classes="filter-chip"
                                    Classes.sel-all="{Binding IsFilterAll}"
                                    Command="{Binding SelectFilterCommand}" CommandParameter="All">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{DynamicResource BrandCategoryAllBrush}" />
                                    <TextBlock Text="全部" VerticalAlignment="Center" />
                                    <Border Classes="count-badge">
                                        <TextBlock Text="{Binding AllCount}" />
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Border Classes="chip-indicator" Classes.active="{Binding IsFilterAll}"
                                    Background="{DynamicResource BrandCategoryAllBrush}" />
                        </Grid>
                        <Grid>
                            <Button Classes="filter-chip"
                                    Classes.sel-running="{Binding IsFilterRunning}"
                                    Command="{Binding SelectFilterCommand}" CommandParameter="Running">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{DynamicResource SystemFillColorAttentionBrush}" />
                                    <TextBlock Text="运行中" VerticalAlignment="Center" />
                                    <Border Classes="count-badge">
                                        <TextBlock Text="{Binding RunningCount}" />
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Border Classes="chip-indicator" Classes.active="{Binding IsFilterRunning}"
                                    Background="{DynamicResource SystemFillColorAttentionBrush}" />
                        </Grid>
                        <Grid>
                            <Button Classes="filter-chip"
                                    Classes.sel-succeeded="{Binding IsFilterSucceeded}"
                                    Command="{Binding SelectFilterCommand}" CommandParameter="Succeeded">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{DynamicResource SystemFillColorSuccessBrush}" />
                                    <TextBlock Text="已完成" VerticalAlignment="Center" />
                                    <Border Classes="count-badge">
                                        <TextBlock Text="{Binding SucceededCount}" />
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Border Classes="chip-indicator" Classes.active="{Binding IsFilterSucceeded}"
                                    Background="{DynamicResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Grid>
                            <Button Classes="filter-chip"
                                    Classes.sel-failed="{Binding IsFilterFailed}"
                                    Command="{Binding SelectFilterCommand}" CommandParameter="Failed">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{DynamicResource SystemFillColorCriticalBrush}" />
                                    <TextBlock Text="失败" VerticalAlignment="Center" />
                                    <Border Classes="count-badge">
                                        <TextBlock Text="{Binding FailedCount}" />
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Border Classes="chip-indicator" Classes.active="{Binding IsFilterFailed}"
                                    Background="{DynamicResource SystemFillColorCriticalBrush}" />
                        </Grid>
                    </StackPanel>

                    <!-- 任务列表 -->
                    <Grid Grid.Row="1">
                        <!-- 空状态 -->
                        <Border IsVisible="{Binding ShowEmpty}"
                                Background="{DynamicResource LayerFillColorAltBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="48,40"
                                Margin="0,16"
                                MaxWidth="480"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="16" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource IconTasks}" Width="60" Height="60"
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                          Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock Text="暂无任务"
                                           HorizontalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="去媒体源页面触发识别后，进度会出现在这里。"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Opacity="0.7"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- 列表（ItemsControl + 卡内"子任务"展开区——不用 TreeView：
                             TreeViewItem 模板自带层级缩进 + 沟槽 chevron + 选中指示条，
                             会让整列右移、与上方 chip/Tab 不对齐）。
                             HorizontalScrollBarVisibility=Disabled：行内容靠 Grid * 列 + 文本省略号自适应宽度，
                             绝不横向滚动——避免长标题把右侧操作按钮顶出可视区。 -->
                        <ScrollViewer IsVisible="{Binding !ShowEmpty}"
                                      HorizontalScrollBarVisibility="Disabled">
                            <!-- Padding 在内容上而非 ScrollViewer：top 3 给 hover lift(-1px)+边框 留余量
                                 不被视口裁顶；right 14 让出浮动滚动条 gutter，避免卡片右边框被滚动条压住 -->
                            <ItemsControl ItemsSource="{Binding Items}" Classes="fade-items"
                                          Padding="2,3,14,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TaskItemViewModel">
                                        <Border Classes="task-row" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto,14,*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                                                <!-- 状态徽 -->
                                                <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="4"
                                                        Classes="status-dot"
                                                        Classes.running="{Binding IsRunning}"
                                                        Classes.done="{Binding IsSucceeded}"
                                                        Classes.failed="{Binding IsFailed}">
                                                    <PathIcon Data="{Binding StatusIconData}"
                                                              Width="17" Height="17"
                                                              Foreground="{Binding StatusBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Border>

                                                <!-- 标题 -->
                                                <TextBlock Grid.Column="2" Grid.Row="0"
                                                           Classes="task-title"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip.Tip="{Binding DisplayName}" />

                                                <!-- 进度条 + 百分比 -->
                                                <Grid Grid.Column="2" Grid.Row="1"
                                                      Margin="0,9,0,0"
                                                      ColumnDefinitions="*,8,Auto"
                                                      IsVisible="{Binding ShowProgressBar}">
                                                    <ProgressBar Grid.Column="0"
                                                                 Classes="slim"
                                                                 Minimum="0" Maximum="100"
                                                                 Value="{Binding ProgressPercentage}"
                                                                 Foreground="{Binding StatusBrush}"
                                                                 VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ProgressText}"
                                                               FontSize="10" Opacity="0.6"
                                                               MinWidth="30" TextAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>

                                                <!-- 状态 / 计时 / 当前项 -->
                                                <Grid Grid.Column="2" Grid.Row="2"
                                                      Margin="0,7,0,0"
                                                      ColumnDefinitions="Auto,*">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                                Spacing="10" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusBrush}" />
                                                        <TextBlock Text="{Binding TimingText}"
                                                                   FontSize="11" Opacity="0.7"
                                                                   IsVisible="{Binding TimingText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CurrentItem}"
                                                               FontSize="11" Opacity="0.5"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               IsVisible="{Binding ShowProgressBar}" />
                                                </Grid>

                                                <!-- 错误信息 -->
                                                <Border Grid.Column="2" Grid.Row="3"
                                                        IsVisible="{Binding HasErrorMessage}"
                                                        Margin="0,8,0,0"
                                                        Padding="10,7"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
                                                    <TextBlock Text="{Binding ErrorMessage}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <!-- 行操作（图标按钮，常驻） -->
                                                <StackPanel Grid.Column="3" Grid.Row="0" Grid.RowSpan="4"
                                                            Orientation="Horizontal" Spacing="2"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <Button Classes="icon-action"
                                                            ToolTip.Tip="查看任务详情"
                                                            Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).OpenTaskDetailsCommand}"
                                                            CommandParameter="{Binding TaskId}">
                                                        <PathIcon Data="{StaticResource IconInfo}" />
                                                    </Button>
                                                    <Button Classes="icon-action"
                                                            ToolTip.Tip="查看本次识别的诊断面板"
                                                            IsVisible="{Binding HasDiagnostics}"
                                                            Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).OpenDiagnosticsCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{StaticResource IconSearch}" />
                                                    </Button>
                                                    <Button Classes="icon-action danger"
                                                            ToolTip.Tip="取消任务"
                                                            IsVisible="{Binding CanCancel}"
                                                            Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).CancelTaskCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{StaticResource IconClose}" />
                                                    </Button>
                                                </StackPanel>

                                                <!-- 子任务展开区（仅批量任务有）：toggle + 内嵌托盘 -->
                                                <StackPanel Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="4"
                                                            IsVisible="{Binding HasChildItems}"
                                                            Margin="0,8,0,0">
                                                    <Button Classes="subtask-toggle"
                                                            Command="{Binding ToggleExpandCommand}">
                                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                                            <PathIcon Classes="chevron"
                                                                      Classes.expanded="{Binding IsExpanded}"
                                                                      Data="{StaticResource IconChevronRight}" />
                                                            <TextBlock Text="子任务" FontSize="12" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ChildrenStatsText}"
                                                                       FontSize="11" Opacity="0.6"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Border Classes="subtask-tray"
                                                            IsVisible="{Binding IsExpanded}">
                                                        <ItemsControl ItemsSource="{Binding ChildItems}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="vm:TaskItemViewModel">
                                                                    <Grid ColumnDefinitions="Auto,10,*,10,Auto"
                                                                          RowDefinitions="Auto,Auto"
                                                                          Margin="0,3,0,3">
                                                                        <!-- 小号状态 tile -->
                                                                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                                                                Classes="status-dot mini"
                                                                                Classes.running="{Binding IsRunning}"
                                                                                Classes.done="{Binding IsSucceeded}"
                                                                                Classes.failed="{Binding IsFailed}">
                                                                            <PathIcon Data="{Binding StatusIconData}"
                                                                                      Width="12" Height="12"
                                                                                      Foreground="{Binding StatusBrush}"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <!-- 标题 -->
                                                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                                                   Text="{Binding DisplayName}"
                                                                                   FontSize="12.5"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Center"
                                                                                   ToolTip.Tip="{Binding DisplayName}" />
                                                                        <!-- 状态 + 进度 -->
                                                                        <Grid Grid.Column="2" Grid.Row="1"
                                                                              Margin="0,3,0,0"
                                                                              ColumnDefinitions="Auto,10,*">
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                                                        Spacing="8" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding StatusText}"
                                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                                           Foreground="{Binding StatusBrush}" />
                                                                                <TextBlock Text="{Binding TimingText}"
                                                                                           FontSize="10.5" Opacity="0.6"
                                                                                           IsVisible="{Binding TimingText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                            </StackPanel>
                                                                            <ProgressBar Grid.Column="2"
                                                                                         Classes="slim"
                                                                                         MaxWidth="160"
                                                                                         HorizontalAlignment="Left"
                                                                                         Minimum="0" Maximum="100"
                                                                                         Value="{Binding ProgressPercentage}"
                                                                                         Foreground="{Binding StatusBrush}"
                                                                                         VerticalAlignment="Center"
                                                                                         IsVisible="{Binding ShowProgressBar}" />
                                                                        </Grid>
                                                                        <!-- 子任务行操作 -->
                                                                        <StackPanel Grid.Column="4" Grid.Row="0" Grid.RowSpan="2"
                                                                                    Orientation="Horizontal" Spacing="2"
                                                                                    VerticalAlignment="Center">
                                                                            <Button Classes="icon-action"
                                                                                    ToolTip.Tip="查看任务详情"
                                                                                    Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).OpenTaskDetailsCommand}"
                                                                                    CommandParameter="{Binding TaskId}">
                                                                                <PathIcon Data="{StaticResource IconInfo}" />
                                                                            </Button>
                                                                            <Button Classes="icon-action"
                                                                                    ToolTip.Tip="查看本次识别的诊断面板"
                                                                                    IsVisible="{Binding HasDiagnostics}"
                                                                                    Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).OpenDiagnosticsCommand}"
                                                                                    CommandParameter="{Binding}">
                                                                                <PathIcon Data="{StaticResource IconSearch}" />
                                                                            </Button>
                                                                            <Button Classes="icon-action danger"
                                                                                    ToolTip.Tip="取消任务"
                                                                                    IsVisible="{Binding CanCancel}"
                                                                                    Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).CancelTaskCommand}"
                                                                                    CommandParameter="{Binding}">
                                                                                <PathIcon Data="{StaticResource IconClose}" />
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============== Tab 1: 历史 ============== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconHistory}" Width="14" Height="14" />
                        <TextBlock Text="历史" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,12,0,0">
                    <!-- 空状态 -->
                    <Border IsVisible="{Binding ShowHistoryEmpty}"
                            Background="{DynamicResource LayerFillColorAltBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="48,40"
                            MaxWidth="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconHistory}" Width="56" Height="56"
                                      Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                      Opacity="0.5" HorizontalAlignment="Center" />
                            <TextBlock Text="暂无执行历史"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="任务执行完成后会归档到这里——进度页清理后这里仍保留。"
                                       Opacity="0.7"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer IsVisible="{Binding !ShowHistoryEmpty}"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding HistoryItems}" Classes="fade-items"
                                      Padding="2,3,14,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HistoryItemViewModel">
                                    <Border Classes="task-row" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,14,*,Auto"
                                              RowDefinitions="Auto,Auto,Auto">

                                            <!-- 状态徽 -->
                                            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                                    Classes="status-dot"
                                                    Classes.done="{Binding Success}"
                                                    Classes.failed="{Binding !Success}">
                                                <PathIcon Data="{Binding StatusIconData}"
                                                          Width="17" Height="17"
                                                          Foreground="{Binding StatusBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>

                                            <!-- 标题 + 类型角标 -->
                                            <Grid Grid.Column="2" Grid.Row="0" ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Classes="task-title"
                                                           Text="{Binding TaskName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip.Tip="{Binding TaskName}" />
                                                <Border Grid.Column="1" Classes="type-badge" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding TaskTypeText}" />
                                                </Border>
                                            </Grid>

                                            <!-- 状态 / 时间 / 耗时 / 处理量（窄宽度自动换行） -->
                                            <WrapPanel Grid.Column="2" Grid.Row="1" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}"
                                                           Margin="0,0,12,0" />
                                                <TextBlock Text="{Binding StartTimeText}"
                                                           FontSize="11" Opacity="0.7"
                                                           Margin="0,0,12,0" />
                                                <TextBlock Text="{Binding DurationText}"
                                                           FontSize="11" Opacity="0.7"
                                                           Margin="0,0,12,0" />
                                                <TextBlock Text="{Binding StatsText}"
                                                           FontSize="11" Opacity="0.7" />
                                            </WrapPanel>

                                            <!-- 源路径（识别类任务） -->
                                            <TextBlock Grid.Column="2" Grid.Row="2"
                                                       Text="{Binding SourcePath}"
                                                       FontSize="11"
                                                       Opacity="0.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas, Courier New, monospace"
                                                       Margin="0,6,0,0"
                                                       ToolTip.Tip="{Binding SourcePath}"
                                                       IsVisible="{Binding HasSourcePath}" />

                                            <!-- 行操作 -->
                                            <Button Grid.Column="3" Grid.Row="0" Grid.RowSpan="3"
                                                    Classes="icon-action"
                                                    Margin="10,0,0,0"
                                                    ToolTip.Tip="查看任务详情（含日志）"
                                                    Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).OpenTaskDetailsCommand}"
                                                    CommandParameter="{Binding TaskId}">
                                                <PathIcon Data="{StaticResource IconInfo}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ============== Tab 2: 定时 ============== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" />
                        <TextBlock Text="定时" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,12,0,0">
                    <Border IsVisible="{Binding ShowScheduledEmpty}"
                            Background="{DynamicResource LayerFillColorAltBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="48,40"
                            MaxWidth="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconClock}" Width="56" Height="56"
                                      Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                      Opacity="0.5" HorizontalAlignment="Center" />
                            <TextBlock Text="无定时任务"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="config.yaml 的 tasks.scheduled_tasks 列表为空。"
                                       Opacity="0.7"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer IsVisible="{Binding !ShowScheduledEmpty}"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ScheduledItems}" Classes="fade-items"
                                      Padding="2,3,14,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ScheduledItemViewModel">
                                    <Border Classes="task-row" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,14,*,Auto"
                                              RowDefinitions="Auto,Auto,Auto">

                                            <!-- 时钟圆徽 -->
                                            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                                    Classes="status-dot"
                                                    Classes.done="{Binding Enabled}">
                                                <PathIcon Data="{StaticResource IconClock}"
                                                          Width="18" Height="18"
                                                          Foreground="{Binding StatusBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>

                                            <!-- 名称 + 类型角标 -->
                                            <Grid Grid.Column="2" Grid.Row="0" ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Classes="task-title"
                                                           Text="{Binding Name}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip.Tip="{Binding Name}" />
                                                <Border Grid.Column="1" Classes="type-badge" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Type}" />
                                                </Border>
                                            </Grid>

                                            <!-- 描述 -->
                                            <TextBlock Grid.Column="2" Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       FontSize="11" Opacity="0.7"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />

                                            <!-- cron + 超时 + 下次/上次执行（窄宽度自动换行） -->
                                            <WrapPanel Grid.Column="2" Grid.Row="2" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding CronExpression, StringFormat='cron: {0}'}"
                                                           FontSize="11"
                                                           FontFamily="Consolas, Courier New, monospace"
                                                           Opacity="0.65"
                                                           Margin="0,0,12,0" />
                                                <TextBlock Text="{Binding TimeoutText, StringFormat='超时: {0}'}"
                                                           FontSize="11" Opacity="0.65"
                                                           Margin="0,0,12,0" />
                                                <!-- 下次执行：启用时高亮 accent，禁用时灰 -->
                                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,0,12,0">
                                                    <PathIcon Data="{StaticResource IconClock}"
                                                              Width="11" Height="11"
                                                              Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                              VerticalAlignment="Center"
                                                              IsVisible="{Binding CanTrigger}" />
                                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                                        <Run Text="下次 " Foreground="{DynamicResource TextFillColorTertiaryBrush}" /><Run Text="{Binding NextRunText}"
                                                             Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Opacity="0.55" VerticalAlignment="Center"
                                                           Text="{Binding LastRunText, StringFormat='上次 {0}'}" />
                                            </WrapPanel>

                                            <!-- 右侧：启用 chip + 立即执行按钮 -->
                                            <StackPanel Grid.Column="3" Grid.Row="0" Grid.RowSpan="3"
                                                        Spacing="8" Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <Border Padding="10,4"
                                                        CornerRadius="12"
                                                        HorizontalAlignment="Right"
                                                        Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                                    <TextBlock Text="{Binding EnabledText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <!-- 立即执行：仅启用任务可点；执行中置灰 + 文案切换 -->
                                                <Button IsVisible="{Binding CanTrigger}"
                                                        IsEnabled="{Binding !IsTriggering}"
                                                        Padding="12,6"
                                                        HorizontalAlignment="Right"
                                                        Command="{Binding #PageRoot.((vm:BackgroundTasksViewModel)DataContext).TriggerScheduledCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="不等下次 cron，立即执行一次">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Data="{StaticResource IconPlay}" Width="12" Height="12"
                                                                  IsVisible="{Binding !IsTriggering}" />
                                                        <TextBlock Text="立即执行" FontSize="12"
                                                                   IsVisible="{Binding !IsTriggering}" />
                                                        <TextBlock Text="执行中…" FontSize="12"
                                                                   IsVisible="{Binding IsTriggering}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>

</UserControl>
