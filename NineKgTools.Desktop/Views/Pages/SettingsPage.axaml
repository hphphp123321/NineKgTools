<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Margin="32,24,32,32" Spacing="16">
        <TextBlock Text="设置" Theme="{StaticResource TitleLargeTextBlockStyle}" />
        <ui:InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="Phase 2.3 待实现"
                    Message="左侧分组导航 + 右侧字段区双列布局 + 即时保存 + 危险操作分隔。" />
    </StackPanel>
</UserControl>
