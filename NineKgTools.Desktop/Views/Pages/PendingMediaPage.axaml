<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.PendingMediaPage"
             x:DataType="vm:PendingMediaViewModel">
    <StackPanel Margin="32,24,32,32" Spacing="16">
        <TextBlock Text="待处理" Theme="{StaticResource TitleLargeTextBlockStyle}" />
        <ui:InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="Phase 1.5 待实现"
                    Message="双 Tab 待识别 / 待入库 + 行级动作（识别 / 手动添加 / 丢弃）+ 批量操作。" />
    </StackPanel>
</UserControl>
