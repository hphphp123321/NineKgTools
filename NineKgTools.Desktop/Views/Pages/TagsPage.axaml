<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.TagsPage"
             x:DataType="vm:TagsViewModel">
    <StackPanel Margin="32,24,32,32" Spacing="16">
        <TextBlock Text="标签" Theme="{StaticResource TitleLargeTextBlockStyle}" />
        <ui:InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="Phase 2.4 待实现"
                    Message="顶级标签列表 → 顶级详情 → 单标签详情，三层结构。" />
    </StackPanel>
</UserControl>
