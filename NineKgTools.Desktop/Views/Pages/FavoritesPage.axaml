<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Pages"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Pages.FavoritesPage"
             x:DataType="vm:FavoritesViewModel">
    <StackPanel Margin="32,24,32,32" Spacing="16">
        <TextBlock Text="收藏夹" Theme="{StaticResource TitleLargeTextBlockStyle}" />
        <ui:InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="Phase 2.6 待实现"
                    Message="左右分栏 + 收藏夹列表 + 多选 + 拖拽到 sidebar。" />
    </StackPanel>
</UserControl>
