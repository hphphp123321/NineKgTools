<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:tags="using:NineKgTools.Core.Models.Tags"
             x:Class="NineKgTools.Desktop.Views.Dialogs.TagEditorDialog"
             x:Name="DialogRoot"
             MinWidth="420" MaxWidth="540">

    <StackPanel Spacing="14">

        <StackPanel Spacing="6">
            <TextBlock Text="标签名称" FontSize="11" Opacity="0.7" />
            <TextBox Text="{Binding #DialogRoot.NameValue, Mode=TwoWay}"
                     Watermark="例如：校园 / 末世 / 治愈..." />
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="所属顶级分组" FontSize="11" Opacity="0.7" />
            <ComboBox ItemsSource="{Binding #DialogRoot.AvailableTopTags}"
                      SelectedItem="{Binding #DialogRoot.SelectedTopTag, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="tags:TopTag">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="描述（可选）" FontSize="11" Opacity="0.7" />
            <TextBox Text="{Binding #DialogRoot.DescriptionValue, Mode=TwoWay}"
                     Watermark="对此标签的简短说明..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="72" />
        </StackPanel>

        <Border IsVisible="{Binding #DialogRoot.ShowEditHint}"
                Padding="12,10"
                CornerRadius="6"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="ⓘ" FontSize="13" VerticalAlignment="Center" />
                <TextBlock Text="{Binding #DialogRoot.EditHintText}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
