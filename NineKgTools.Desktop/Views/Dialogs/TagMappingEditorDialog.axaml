<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Dialogs.TagMappingEditorDialog"
             x:Name="DialogRoot"
             MinWidth="440" MaxWidth="540">

    <StackPanel Spacing="14">

        <!-- 源标签名称 -->
        <StackPanel Spacing="6">
            <TextBlock Text="源标签名称" FontSize="11" Opacity="0.7" />
            <TextBox Text="{Binding #DialogRoot.SourceNameValue, Mode=TwoWay}"
                     PlaceholderText="例如：纯爱 / 美少女游戏..." />
            <TextBlock Text="识别到此名称时将自动映射到下方目标标签"
                       FontSize="11" Opacity="0.55" />
        </StackPanel>

        <!-- 目标标签 -->
        <StackPanel Spacing="6">
            <TextBlock Text="目标标签" FontSize="11" Opacity="0.7" />
            <Grid ColumnDefinitions="*,8,Auto">
                <Border Grid.Column="0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="11,8"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding #DialogRoot.TargetTagDisplay}"
                                   FontSize="13" />
                        <TextBlock Text="{Binding #DialogRoot.TargetTagSubText}"
                                   FontSize="11" Opacity="0.6"
                                   IsVisible="{Binding #DialogRoot.HasTargetTagSubText}" />
                    </StackPanel>
                </Border>
                <Button Grid.Column="2"
                        Click="OnSelectTargetTag"
                        Padding="14,8"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="13" />
                        <TextBlock Text="{Binding #DialogRoot.SelectButtonText}" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <!-- 描述（可选） -->
        <StackPanel Spacing="6">
            <TextBlock Text="描述（可选）" FontSize="11" Opacity="0.7" />
            <TextBox Text="{Binding #DialogRoot.DescriptionValue, Mode=TwoWay}"
                     PlaceholderText="备注此映射的来源 / 原因..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60" />
        </StackPanel>

        <!-- 内联错误（重复源名 / 提交失败等） -->
        <Border IsVisible="{Binding #DialogRoot.HasErrorMessage}"
                Padding="12,8"
                CornerRadius="6"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" FontSize="13" VerticalAlignment="Center" />
                <TextBlock Text="{Binding #DialogRoot.ErrorMessage}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
