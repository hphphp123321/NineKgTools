<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NineKgTools.Desktop.Views.Dialogs.InputDialog"
             x:Name="DialogRoot"
             MinWidth="380" MaxWidth="520">

    <StackPanel Spacing="10">

        <TextBlock IsVisible="{Binding #DialogRoot.HasMessage}"
                   Text="{Binding #DialogRoot.MessageText}"
                   FontSize="13"
                   Opacity="0.85"
                   TextWrapping="Wrap" />

        <TextBox x:Name="ValueBox"
                 Text="{Binding #DialogRoot.InputValue, Mode=TwoWay}"
                 PlaceholderText="{Binding #DialogRoot.Placeholder}"
                 MaxLength="{Binding #DialogRoot.MaxLength}" />

        <TextBlock IsVisible="{Binding #DialogRoot.HasHelperText}"
                   Text="{Binding #DialogRoot.HelperText}"
                   FontSize="11"
                   Opacity="0.55"
                   TextWrapping="Wrap" />

    </StackPanel>

</UserControl>
