<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Dialogs"
             x:Class="NineKgTools.Desktop.Views.Dialogs.FavoriteSelectorDialog"
             x:DataType="vm:FavoriteSelectorDialogContext"
             MinWidth="480" MaxWidth="640">

    <StackPanel Spacing="12">

        <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                 PlaceholderText="搜索收藏夹..." />

        <Border Padding="10,6"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Background="{DynamicResource LayerFillColorDefaultBrush}">
            <TextBlock Text="{Binding SelectionLabel}" FontSize="12" Opacity="0.8" />
        </Border>

        <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True" />

        <Border IsVisible="{Binding ShowEmpty}"
                Padding="14,10"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
            <TextBlock Text="没有匹配的收藏夹" FontSize="12" />
        </Border>

        <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredChoices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FavoriteChoiceVm">
                        <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,0,8,8"
                                      Padding="14,6"
                                      CornerRadius="14">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="★" FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DisplayName}" FontSize="12" />
                                <TextBlock IsVisible="{Binding HasCount}"
                                           Text="{Binding CountText}"
                                           FontSize="11"
                                           Opacity="0.55" />
                            </StackPanel>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </StackPanel>

</UserControl>
