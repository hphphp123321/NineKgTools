<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Dialogs"
             x:Class="NineKgTools.Desktop.Views.Dialogs.PendingMediaPreviewDialog"
             x:DataType="vm:PendingMediaPreviewDialogContext"
             MinWidth="540" MaxWidth="720">

    <ScrollViewer MaxHeight="540" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">

            <!-- Hero：标题 + 路径 + 类别 chip -->
            <Border Padding="16,12"
                    CornerRadius="{DynamicResource OverlayCornerRadius}"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Title}"
                               Theme="{StaticResource SubtitleTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SourcePath}"
                               FontSize="11"
                               Opacity="0.65"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               FontFamily="Consolas, Courier New, monospace" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Border Padding="8,2" CornerRadius="4"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <TextBlock Text="{Binding TopCategoryName}" FontSize="11" />
                        </Border>
                        <Border Padding="8,2" CornerRadius="4"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <TextBlock Text="{Binding CategoryName}" FontSize="11" />
                        </Border>
                        <TextBlock IsVisible="{Binding HasRating}"
                                   Text="{Binding RatingText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 创作者 / 社团 -->
            <Grid IsVisible="{Binding HasCreators}"
                  ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="创作者" FontSize="12" Opacity="0.7"
                           VerticalAlignment="Top" Margin="0,2,0,0" />
                <TextBlock Grid.Column="1" Text="{Binding CreatorsText}"
                           FontSize="13" TextWrapping="Wrap" />
            </Grid>
            <Grid IsVisible="{Binding HasCircle}"
                  ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="社团" FontSize="12" Opacity="0.7"
                           VerticalAlignment="Top" Margin="0,2,0,0" />
                <TextBlock Grid.Column="1" Text="{Binding CircleName}"
                           FontSize="13" TextWrapping="Wrap" />
            </Grid>

            <!-- 别名 -->
            <Grid IsVisible="{Binding HasAlias}"
                  ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="别名" FontSize="12" Opacity="0.7"
                           VerticalAlignment="Top" Margin="0,2,0,0" />
                <TextBlock Grid.Column="1" Text="{Binding AliasText}"
                           FontSize="13" Opacity="0.85" TextWrapping="Wrap" />
            </Grid>

            <!-- 发售日期 -->
            <Grid IsVisible="{Binding HasReleaseDate}"
                  ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="发售日期" FontSize="12" Opacity="0.7"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding ReleaseDateText}"
                           FontSize="13" />
            </Grid>

            <!-- 标签 chip -->
            <StackPanel IsVisible="{Binding HasTags}" Spacing="6">
                <TextBlock Text="标签" FontSize="12" Opacity="0.7" />
                <ItemsControl ItemsSource="{Binding Tags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,4" Margin="0,0,6,6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Text="{Binding}" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- 简介 -->
            <StackPanel Spacing="6">
                <TextBlock Text="简介" FontSize="12" Opacity="0.7" />
                <Border Padding="12,10"
                        CornerRadius="{DynamicResource ControlCornerRadius}"
                        Background="{DynamicResource LayerFillColorAltBrush}">
                    <TextBlock Text="{Binding Summary}"
                               FontSize="13"
                               LineHeight="20"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- 详细描述（如果与简介不同） -->
            <StackPanel Spacing="6" IsVisible="{Binding HasDescription}">
                <Expander Header="详细描述">
                    <TextBlock Text="{Binding Description}"
                               FontSize="12"
                               LineHeight="18"
                               Opacity="0.85"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </Expander>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
