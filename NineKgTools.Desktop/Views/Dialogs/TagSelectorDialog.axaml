<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Dialogs"
             x:Class="NineKgTools.Desktop.Views.Dialogs.TagSelectorDialog"
             x:DataType="vm:TagSelectorDialogContext"
             MinWidth="520" MaxWidth="700">

    <StackPanel Spacing="12">

        <!-- 搜索框 -->
        <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                 PlaceholderText="搜索标签名 / 顶级分组..." />

        <!-- 已选预览 + 计数 -->
        <Border Padding="10,6"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Background="{DynamicResource LayerFillColorDefaultBrush}">
            <TextBlock Text="{Binding SelectionLabel}" FontSize="12" Opacity="0.8" />
        </Border>

        <!-- 加载中 -->
        <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True" />

        <!-- 空结果 -->
        <Border IsVisible="{Binding ShowEmpty}"
                Padding="14,10"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
            <TextBlock Text="没有匹配的标签" FontSize="12" />
        </Border>

        <!-- chip 列表 -->
        <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredChoices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TagChoiceVm">
                        <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,0,8,8"
                                      Padding="12,5"
                                      CornerRadius="14">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding DisplayName}" FontSize="12" />
                                <TextBlock IsVisible="{Binding HasGroupHint}"
                                           Text="{Binding GroupHint, StringFormat='/{0}'}"
                                           FontSize="11"
                                           Opacity="0.55" />
                            </StackPanel>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </StackPanel>

</UserControl>
