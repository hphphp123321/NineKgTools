<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NineKgTools.Desktop.ViewModels.Dialogs"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Dialogs.NineKgConfirmDialog"
             x:DataType="vm:NineKgConfirmDialogContext"
             MinWidth="420" MaxWidth="560">

    <StackPanel Spacing="16">

        <!-- 主消息 -->
        <TextBlock Text="{Binding Message}"
                   Theme="{StaticResource BodyTextBlockStyle}"
                   TextWrapping="Wrap" />

        <!-- Destructive 专属：目标名预览卡 -->
        <Border IsVisible="{Binding ShowTargetName}"
                Padding="14,10"
                CornerRadius="{StaticResource OverlayCornerRadius}"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                BorderThickness="1">
            <StackPanel Spacing="2">
                <TextBlock Text="目标" FontSize="11" Opacity="0.6" />
                <TextBlock Text="{Binding TargetName}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- DestructiveBatch 专属：Hero count 卡 -->
        <Border IsVisible="{Binding ShowHeroCount}"
                Padding="20,16"
                CornerRadius="{StaticResource OverlayCornerRadius}"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                BorderThickness="1">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="{Binding AffectedCount}"
                           Theme="{StaticResource DisplayTextBlockStyle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="将被永久删除"
                           HorizontalAlignment="Center"
                           Opacity="0.8" />
                <ItemsControl ItemsSource="{Binding TargetItems}"
                              Margin="0,8,0,0"
                              MaxHeight="120">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat='· {0}'}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Destructive* 专属：不可撤销警告条 -->
        <Border IsVisible="{Binding ShowWarningBar}"
                Padding="12,10"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="此操作不可撤销。"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
