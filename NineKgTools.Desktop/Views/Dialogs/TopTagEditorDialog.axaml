<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="NineKgTools.Desktop.Views.Dialogs.TopTagEditorDialog"
             x:Name="DialogRoot"
             MinWidth="380" MaxWidth="480">

    <StackPanel Spacing="14">

        <TextBlock Text="顶级标签是子标签的分组容器，例如 风格 / 题材 / 角色 / 系列。"
                   FontSize="12"
                   Opacity="0.7"
                   TextWrapping="Wrap" />

        <StackPanel Spacing="6">
            <TextBlock Text="名称" FontSize="11" Opacity="0.7" />
            <TextBox x:Name="NameInput"
                     Text="{Binding #DialogRoot.NameValue, Mode=TwoWay}"
                     Watermark="例如：风格 / 题材 / 角色..." />
        </StackPanel>

        <Border IsVisible="{Binding #DialogRoot.ShowEditHint}"
                Padding="12,10"
                CornerRadius="6"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="ⓘ" FontSize="13" VerticalAlignment="Center" />
                <TextBlock Text="{Binding #DialogRoot.EditHintText}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
