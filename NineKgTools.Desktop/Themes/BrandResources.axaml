<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        视觉 token：项目自定义部分
        99% 的颜色 / 字号 / 间距 走 FluentAvalonia 默认 resource。
        本文件定义品牌特色点：类别色 / Hero 渐变 / 项目图标库 / 字体。
    -->

    <!-- ========== Inter 字体（Phase 0 已引入包，此处声明 FontFamily 资源） ========== -->
    <FontFamily x:Key="BrandFontFamily">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>

    <!-- ========== 5 类别签名色 ========== -->
    <!-- 用于：分类切换栏边框、媒体卡 badge、TopTag chip 描边、标签管理顶级标签卡 -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <!-- 浅色主题：浅蓝→浅紫，对比度温和 -->
            <LinearGradientBrush x:Key="BrandHeroGradient"
                                 StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#E8F0FB" Offset="0" />
                <GradientStop Color="#EDE8F6" Offset="0.5" />
                <GradientStop Color="#F5E8F0" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BrandHeroOverlay"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#E0FFFFFF" Offset="0" />
                <GradientStop Color="#80FFFFFF" Offset="0.6" />
                <GradientStop Color="#00FFFFFF" Offset="1" />
            </LinearGradientBrush>

            <!-- 类别色（浅色主题：饱和度高，对比白底清晰） -->
            <SolidColorBrush x:Key="BrandCategoryVideoBrush" Color="#5B6BC9" />
            <SolidColorBrush x:Key="BrandCategoryAudioBrush" Color="#E89B5C" />
            <SolidColorBrush x:Key="BrandCategoryGameBrush" Color="#3DAA8B" />
            <SolidColorBrush x:Key="BrandCategoryPictureBrush" Color="#E66B95" />
            <SolidColorBrush x:Key="BrandCategoryTextBrush" Color="#C4A76B" />

            <!-- 类别色 fill（带 alpha 用于卡片背景） -->
            <SolidColorBrush x:Key="BrandCategoryVideoFillBrush" Color="#205B6BC9" />
            <SolidColorBrush x:Key="BrandCategoryAudioFillBrush" Color="#20E89B5C" />
            <SolidColorBrush x:Key="BrandCategoryGameFillBrush" Color="#203DAA8B" />
            <SolidColorBrush x:Key="BrandCategoryPictureFillBrush" Color="#20E66B95" />
            <SolidColorBrush x:Key="BrandCategoryTextFillBrush" Color="#20C4A76B" />

            <!-- "全部" 中性紫灰（与 5 类别同级，但用作"无筛选"语义） -->
            <SolidColorBrush x:Key="BrandCategoryAllBrush" Color="#7B6F8E" />
            <SolidColorBrush x:Key="BrandCategoryAllFillBrush" Color="#207B6F8E" />

            <!-- 任务状态浅色 fill（用于过滤 chip 选中背景；stroke 直接复用 SystemFillColor 系列） -->
            <SolidColorBrush x:Key="BrandStatusRunningFillBrush" Color="#2055B3F0" />
            <SolidColorBrush x:Key="BrandStatusSuccessFillBrush" Color="#206BCFA8" />
            <SolidColorBrush x:Key="BrandStatusFailedFillBrush" Color="#20E55353" />

            <!-- ========== 媒体详情玻璃材质背景（浅色） ==========
                亮色玻璃 = 45% 半透白膜（v2 减压）+ 30% 暗角 + 顶部白色微提亮。
                v2 修复（与 BlurHelper σ=24 + Saturate 1.6 配套）：
                  原 65% 白 tint 在已经磨成色块的封面上再盖一层 → "一团光球"看不出封面；
                  现在 blur 半径砍到 1/3 + 饱和度增强保留封面识别度后，tint 可以减压；
                  靠内容卡自带 Layer brush 半透 fill 补足文字对比，不再依赖背景层强暗化。
            -->
            <SolidColorBrush x:Key="GlassTintBrush" Color="#73FFFFFF" />
            <RadialGradientBrush x:Key="GlassVignetteBrush"
                                 Center="50%,50%" GradientOrigin="50%,50%"
                                 RadiusX="85%" RadiusY="85%">
                <GradientStop Offset="0.45" Color="#00000000" />
                <GradientStop Offset="1.0"  Color="#4D000000" />
            </RadialGradientBrush>
            <LinearGradientBrush x:Key="GlassTopGradientBrush"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0.0" Color="#1AFFFFFF" />
                <GradientStop Offset="1.0" Color="#00FFFFFF" />
            </LinearGradientBrush>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <!-- 深色主题：饱和度调低 + 亮度提高，避免太刺眼 -->
            <LinearGradientBrush x:Key="BrandHeroGradient"
                                 StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1E2940" Offset="0" />
                <GradientStop Color="#262040" Offset="0.5" />
                <GradientStop Color="#3D2540" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BrandHeroOverlay"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#E0000000" Offset="0" />
                <GradientStop Color="#80000000" Offset="0.6" />
                <GradientStop Color="#00000000" Offset="1" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="BrandCategoryVideoBrush" Color="#8B95D9" />
            <SolidColorBrush x:Key="BrandCategoryAudioBrush" Color="#F0B47A" />
            <SolidColorBrush x:Key="BrandCategoryGameBrush" Color="#6CC5A8" />
            <SolidColorBrush x:Key="BrandCategoryPictureBrush" Color="#F095B0" />
            <SolidColorBrush x:Key="BrandCategoryTextBrush" Color="#D8C28F" />

            <SolidColorBrush x:Key="BrandCategoryVideoFillBrush" Color="#308B95D9" />
            <SolidColorBrush x:Key="BrandCategoryAudioFillBrush" Color="#30F0B47A" />
            <SolidColorBrush x:Key="BrandCategoryGameFillBrush" Color="#306CC5A8" />
            <SolidColorBrush x:Key="BrandCategoryPictureFillBrush" Color="#30F095B0" />
            <SolidColorBrush x:Key="BrandCategoryTextFillBrush" Color="#30D8C28F" />

            <!-- "全部" 中性紫灰 -->
            <SolidColorBrush x:Key="BrandCategoryAllBrush" Color="#A89AC0" />
            <SolidColorBrush x:Key="BrandCategoryAllFillBrush" Color="#30A89AC0" />

            <!-- 任务状态浅色 fill -->
            <SolidColorBrush x:Key="BrandStatusRunningFillBrush" Color="#3079D2F5" />
            <SolidColorBrush x:Key="BrandStatusSuccessFillBrush" Color="#308BDFB6" />
            <SolidColorBrush x:Key="BrandStatusFailedFillBrush" Color="#30F08080" />

            <!-- ========== 媒体详情玻璃材质背景（深色） ==========
                暗色玻璃 = 30% 黑（v2 减压）+ 45% 暗角 + 顶部黑色高光。
                v2 修复（与 BlurHelper σ=24 + Saturate 1.6 配套）：
                  原 40% 黑 tint 在已被磨成色场的封面上再盖一层 → 几乎纯黑看不见封面；
                  现在 blur 砍到 1/3 + 饱和度增强后 tint 可以降到 30%，封面色透出来识别度回归；
                  vignette 略加补回"聚焦中心"的视觉。
            -->
            <SolidColorBrush x:Key="GlassTintBrush" Color="#4D000000" />
            <RadialGradientBrush x:Key="GlassVignetteBrush"
                                 Center="50%,50%" GradientOrigin="50%,50%"
                                 RadiusX="85%" RadiusY="85%">
                <GradientStop Offset="0.45" Color="#00000000" />
                <GradientStop Offset="1.0"  Color="#73000000" />
            </RadialGradientBrush>
            <LinearGradientBrush x:Key="GlassTopGradientBrush"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0.0" Color="#40000000" />
                <GradientStop Offset="1.0" Color="#00000000" />
            </LinearGradientBrush>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ========== 圆角 / 尺寸 ========== -->
    <CornerRadius x:Key="BrandLargeCornerRadius">12</CornerRadius>
    <x:Double x:Key="BrandActionBarHeight">56</x:Double>
    <x:Double x:Key="BrandHeroHeight">380</x:Double>

    <!-- ========== 项目图标库（Material Design Icons，path data 内嵌） ==========
        来自 https://materialdesignicons.com（Pictogrammers，Apache 2.0）
        风格：填充式、清晰、现代——比 Segoe Fluent Icons 更有标识度
        使用：<ui:FAPathIconSource Data="{StaticResource IconHome}" />
    -->

