<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        视觉 token：项目自定义部分
        99% 的颜色 / 字号 / 间距 走 FluentAvalonia 默认 resource。
        本文件定义品牌特色点：类别色 / Hero 渐变 / 项目图标库 / 字体。
    -->

    <!-- ========== Inter 字体（Phase 0 已引入包，此处声明 FontFamily 资源） ========== -->
    <FontFamily x:Key="BrandFontFamily">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>

    <!-- ========== 5 类别签名色 ========== -->
    <!-- 用于：分类切换栏边框、媒体卡 badge、TopTag chip 描边、标签管理顶级标签卡 -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <!-- 浅色主题：浅蓝→浅紫，对比度温和 -->
            <LinearGradientBrush x:Key="BrandHeroGradient"
                                 StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#E8F0FB" Offset="0" />
                <GradientStop Color="#EDE8F6" Offset="0.5" />
                <GradientStop Color="#F5E8F0" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BrandHeroOverlay"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#E0FFFFFF" Offset="0" />
                <GradientStop Color="#80FFFFFF" Offset="0.6" />
                <GradientStop Color="#00FFFFFF" Offset="1" />
            </LinearGradientBrush>

            <!-- 类别色（浅色主题：饱和度高，对比白底清晰） -->
            <SolidColorBrush x:Key="BrandCategoryVideoBrush" Color="#5B6BC9" />
            <SolidColorBrush x:Key="BrandCategoryAudioBrush" Color="#E89B5C" />
            <SolidColorBrush x:Key="BrandCategoryGameBrush" Color="#3DAA8B" />
            <SolidColorBrush x:Key="BrandCategoryPictureBrush" Color="#E66B95" />
            <SolidColorBrush x:Key="BrandCategoryTextBrush" Color="#C4A76B" />

            <!-- 类别色 fill（带 alpha 用于卡片背景） -->
            <SolidColorBrush x:Key="BrandCategoryVideoFillBrush" Color="#205B6BC9" />
            <SolidColorBrush x:Key="BrandCategoryAudioFillBrush" Color="#20E89B5C" />
            <SolidColorBrush x:Key="BrandCategoryGameFillBrush" Color="#203DAA8B" />
            <SolidColorBrush x:Key="BrandCategoryPictureFillBrush" Color="#20E66B95" />
            <SolidColorBrush x:Key="BrandCategoryTextFillBrush" Color="#20C4A76B" />

            <!-- "全部" 中性紫灰（与 5 类别同级，但用作"无筛选"语义） -->
            <SolidColorBrush x:Key="BrandCategoryAllBrush" Color="#7B6F8E" />
            <SolidColorBrush x:Key="BrandCategoryAllFillBrush" Color="#207B6F8E" />

            <!-- 任务状态浅色 fill（用于过滤 chip 选中背景；stroke 直接复用 SystemFillColor 系列） -->
            <SolidColorBrush x:Key="BrandStatusRunningFillBrush" Color="#2055B3F0" />
            <SolidColorBrush x:Key="BrandStatusSuccessFillBrush" Color="#206BCFA8" />
            <SolidColorBrush x:Key="BrandStatusFailedFillBrush" Color="#20E55353" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <!-- 深色主题：饱和度调低 + 亮度提高，避免太刺眼 -->
            <LinearGradientBrush x:Key="BrandHeroGradient"
                                 StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1E2940" Offset="0" />
                <GradientStop Color="#262040" Offset="0.5" />
                <GradientStop Color="#3D2540" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BrandHeroOverlay"
                                 StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#E0000000" Offset="0" />
                <GradientStop Color="#80000000" Offset="0.6" />
                <GradientStop Color="#00000000" Offset="1" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="BrandCategoryVideoBrush" Color="#8B95D9" />
            <SolidColorBrush x:Key="BrandCategoryAudioBrush" Color="#F0B47A" />
            <SolidColorBrush x:Key="BrandCategoryGameBrush" Color="#6CC5A8" />
            <SolidColorBrush x:Key="BrandCategoryPictureBrush" Color="#F095B0" />
            <SolidColorBrush x:Key="BrandCategoryTextBrush" Color="#D8C28F" />

            <SolidColorBrush x:Key="BrandCategoryVideoFillBrush" Color="#308B95D9" />
            <SolidColorBrush x:Key="BrandCategoryAudioFillBrush" Color="#30F0B47A" />
            <SolidColorBrush x:Key="BrandCategoryGameFillBrush" Color="#306CC5A8" />
            <SolidColorBrush x:Key="BrandCategoryPictureFillBrush" Color="#30F095B0" />
            <SolidColorBrush x:Key="BrandCategoryTextFillBrush" Color="#30D8C28F" />

            <!-- "全部" 中性紫灰 -->
            <SolidColorBrush x:Key="BrandCategoryAllBrush" Color="#A89AC0" />
            <SolidColorBrush x:Key="BrandCategoryAllFillBrush" Color="#30A89AC0" />

            <!-- 任务状态浅色 fill -->
            <SolidColorBrush x:Key="BrandStatusRunningFillBrush" Color="#3079D2F5" />
            <SolidColorBrush x:Key="BrandStatusSuccessFillBrush" Color="#308BDFB6" />
            <SolidColorBrush x:Key="BrandStatusFailedFillBrush" Color="#30F08080" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ========== 圆角 / 尺寸 ========== -->
    <CornerRadius x:Key="BrandLargeCornerRadius">12</CornerRadius>
    <x:Double x:Key="BrandActionBarHeight">56</x:Double>
    <x:Double x:Key="BrandHeroHeight">380</x:Double>

    <!-- ========== 项目图标库（Material Design Icons，path data 内嵌） ==========
        来自 https://materialdesignicons.com（Pictogrammers，Apache 2.0）
        风格：填充式、清晰、现代——比 Segoe Fluent Icons 更有标识度
        使用：<ui:FAPathIconSource Data="{StaticResource IconHome}" />
    -->

    <!-- 侧栏导航图标 -->
    <StreamGeometry x:Key="IconHome">M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z</StreamGeometry>
    <StreamGeometry x:Key="IconLibrary">M9,3V18H12V3H9M14,5V18H17V5H14M5,5V18H7V5H5M3,20V22H21V20H3Z</StreamGeometry>
    <StreamGeometry x:Key="IconInbox">M19,15H15A3,3 0 0,1 12,18A3,3 0 0,1 9,15H5V5H19M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3Z</StreamGeometry>
    <StreamGeometry x:Key="IconFolderOpen">M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z</StreamGeometry>
    <StreamGeometry x:Key="IconTasks">M3,5H9V11H3V5M5,7V9H7V7H5M11,7H21V9H11V7M11,15H21V17H11V15M5,20L1.5,16.5L2.91,15.09L5,17.17L9.59,12.59L11,14L5,20Z</StreamGeometry>
    <!-- 刷新（圆形带箭头）—— 用于刷新 / 重新加载 / 重新识别 等"重做"语义 -->
    <StreamGeometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</StreamGeometry>
    <!-- 收件箱+下箭头（待入库语义，区分于 IconInbox 的"待识别"） -->
    <StreamGeometry x:Key="IconInboxArrowDown">M14,14H10V11H8L12,7L16,11H14V14M16.5,17H7.5L6.5,15H17.5M19,15L17,11V5A2,2 0 0,0 15,3H9C7.89,3 7,3.89 7,5V11L5,15V20A2,2 0 0,0 7,22H17A2,2 0 0,0 19,20V15Z</StreamGeometry>
    <StreamGeometry x:Key="IconTags">M5.5,9A1.5,1.5 0 0,0 7,7.5A1.5,1.5 0 0,0 5.5,6A1.5,1.5 0 0,0 4,7.5A1.5,1.5 0 0,0 5.5,9M17.41,11.58C17.77,11.94 18,12.44 18,13C18,13.55 17.78,14.05 17.41,14.41L12.41,19.41C12.05,19.77 11.55,20 11,20C10.45,20 9.95,19.78 9.58,19.41L2.59,12.42C2.22,12.05 2,11.55 2,11V6C2,4.89 2.89,4 4,4H9C9.55,4 10.05,4.22 10.41,4.58L17.41,11.58M13.54,5.71L14.54,4.71L21.41,11.58C21.77,11.94 22,12.45 22,13C22,13.55 21.78,14.05 21.42,14.41L16.04,19.79L15.04,18.79L20.75,13L13.54,5.71Z</StreamGeometry>
    <StreamGeometry x:Key="IconCreators">M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,13C5.67,13 1,14.17 1,16.5V19H15V16.5C15,14.17 10.33,13 8,13M8,11A3,3 0 0,0 11,8A3,3 0 0,0 8,5A3,3 0 0,0 5,8A3,3 0 0,0 8,11M16,11A3,3 0 0,0 19,8A3,3 0 0,0 16,5A3,3 0 0,0 13,8A3,3 0 0,0 16,11Z</StreamGeometry>
    <StreamGeometry x:Key="IconStar">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M14.81,15.69L14,12.16L16.71,9.81L13.16,9.5L11.75,6.19L10.34,9.5L6.78,9.81L9.5,12.16L8.66,15.69L11.75,13.81L14.81,15.69Z</StreamGeometry>
    <StreamGeometry x:Key="IconWeb">M16.36,14C16.44,13.34 16.5,12.68 16.5,12C16.5,11.32 16.44,10.66 16.36,10H19.74C19.9,10.64 20,11.31 20,12C20,12.69 19.9,13.36 19.74,14M14.59,19.56C15.19,18.45 15.65,17.25 15.97,16H18.92C17.96,17.65 16.43,18.93 14.59,19.56M14.34,14H9.66C9.56,13.34 9.5,12.68 9.5,12C9.5,11.32 9.56,10.65 9.66,10H14.34C14.43,10.65 14.5,11.32 14.5,12C14.5,12.68 14.43,13.34 14.34,14M12,19.96C11.17,18.76 10.5,17.43 10.09,16H13.91C13.5,17.43 12.83,18.76 12,19.96M8,8H5.08C6.03,6.34 7.57,5.06 9.4,4.44C8.8,5.55 8.35,6.75 8,8M5.08,16H8C8.35,17.25 8.8,18.45 9.4,19.56C7.57,18.93 6.03,17.65 5.08,16M4.26,14C4.1,13.36 4,12.69 4,12C4,11.31 4.1,10.64 4.26,10H7.64C7.56,10.66 7.5,11.32 7.5,12C7.5,12.68 7.56,13.34 7.64,14M12,4.03C12.83,5.23 13.5,6.57 13.91,8H10.09C10.5,6.57 11.17,5.23 12,4.03M18.92,8H15.97C15.65,6.75 15.19,5.55 14.59,4.44C16.43,5.07 17.96,6.34 18.92,8M12,2C6.47,2 2,6.5 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z</StreamGeometry>

    <!-- 5 类别图标（用于分类切换栏 + 媒体卡片 fallback） -->
    <StreamGeometry x:Key="IconCategoryVideo">M18,4l2,4h-3l-2-4h-2l2,4h-3l-2-4h-2l2,4h-3l-2-4H4C2.89,4 2,4.89 2,6v12c0,1.1 0.89,2 2,2h16c1.11,0 2-0.9 2-2V4H18z</StreamGeometry>
    <StreamGeometry x:Key="IconCategoryAudio">M12,3A9,9 0 0,0 3,12V18A3,3 0 0,0 6,21H9V12H5V12A7,7 0 0,1 12,5A7,7 0 0,1 19,12V12H15V21H18A3,3 0 0,0 21,18V12A9,9 0 0,0 12,3Z</StreamGeometry>
    <StreamGeometry x:Key="IconCategoryGame">M7.97,16L5,19C4.67,19.3 4.23,19.5 3.75,19.5A1.75,1.75 0 0,1 2,17.75V17.5L3,10.12C3.21,7.81 5.14,6 7.5,6H16.5C18.86,6 20.79,7.81 21,10.12L22,17.5V17.75A1.75,1.75 0 0,1 20.25,19.5C19.77,19.5 19.33,19.3 19,19L16.03,16H7.97M7,8V10H5V11H7V13H8V11H10V10H8V8H7M16.5,9A0.75,0.75 0 0,0 15.75,9.75A0.75,0.75 0 0,0 16.5,10.5A0.75,0.75 0 0,0 17.25,9.75A0.75,0.75 0 0,0 16.5,9M14.75,10.75A0.75,0.75 0 0,0 14,11.5A0.75,0.75 0 0,0 14.75,12.25A0.75,0.75 0 0,0 15.5,11.5A0.75,0.75 0 0,0 14.75,10.75Z</StreamGeometry>
    <StreamGeometry x:Key="IconCategoryPicture">M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M13.96,12.29L11.21,15.83L9.25,13.47L6.5,17H17.5L13.96,12.29Z</StreamGeometry>
    <StreamGeometry x:Key="IconCategoryText">M19,2L14,6.5V17.5L19,13V2M6.5,5C4.55,5 2.45,5.4 1,6.5V21.16C1,21.41 1.25,21.66 1.5,21.66C1.6,21.66 1.65,21.59 1.75,21.59C3.1,20.94 5.05,20.5 6.5,20.5C8.45,20.5 10.55,20.9 12,22C13.35,21.15 15.8,20.5 17.5,20.5C19.15,20.5 20.85,20.81 22.25,21.56C22.35,21.61 22.4,21.59 22.5,21.59C22.75,21.59 23,21.34 23,21.09V6.5C22.4,6.05 21.75,5.75 21,5.5V19C19.9,18.65 18.7,18.5 17.5,18.5C15.8,18.5 13.35,19.15 12,20V6.5C10.55,5.4 8.45,5 6.5,5Z</StreamGeometry>

</ResourceDictionary>
