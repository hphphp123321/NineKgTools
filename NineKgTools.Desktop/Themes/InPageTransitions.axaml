<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Reusable in-page tab/data switch fade-in style.

        Usage: add Classes="fade-items" to the ItemsControl itself.
        Each new ContentPresenter container attach triggers a 200ms
        opacity fade-in.

        Why class is on ItemsControl, not on the panel:
        Avalonia's ChildSelector ('>') walks the LOGICAL tree, not the
        visual tree. ItemsControl synthesises a ContentPresenter for each
        VM item, but PanelContainerGenerator inserts the container as a
        VISUAL child of the panel and a LOGICAL child of the ItemsControl
        (PanelContainerGenerator.cs:128-151). So in the logical tree,
        ContentPresenter.LogicalParent is the ItemsControl. Putting the
        class on the panel makes the selector miss every item.

        Why explicit Setter Opacity=0:
        Style.Animations auto-fire when the style first applies, but the
        first frame can render before the 0%-cue Setter takes effect. An
        explicit Setter writes Opacity=0 at style-apply time, then the
        animation ramps to 1, eliminating the flash.

        Caveat: do NOT apply to virtualizing lists (TreeView with
        virtualization on). Recycled containers re-fade on scroll.
    -->
    <Style Selector="ItemsControl.fade-items > ContentPresenter">
        <Setter Property="Opacity" Value="0" />
        <Style.Animations>
            <Animation Duration="0:0:0.32" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
