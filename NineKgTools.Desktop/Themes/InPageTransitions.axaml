<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Reusable in-page tab/data switch fade-in style.

        Usage: add Classes="fade-items" to an ItemsControl's ItemsPanel
        (WrapPanel / StackPanel). When ItemsSource is replaced (e.g. category
        tab switch), each new ContentPresenter attach triggers a 200ms
        opacity fade-in.

        Two important Avalonia 12 details that broke v1:
        - Panel is abstract; type selector "Panel" does NOT match WrapPanel
          or StackPanel by default. Must use :is(Panel) for base-class match.
        - ItemsControl wraps each item in a ContentPresenter when the item
          is a ViewModel (not a Control). The selector must target
          ContentPresenter, not the DataTemplate root.
        - Style.Animations fire when the selector starts matching, but the
          initial state at frame 0 is brittle — without an explicit Setter
          Property="Opacity" Value="0", the first frame can render at 1.

        Goal: keep cross-page transition (FadeSlideUpTransition with 8px slide)
        distinct from in-page transition (no Y movement). Y movement on tab
        switch causes vertical jitter, hence opacity-only here.

        Caveat: do NOT apply to virtualizing lists (TreeView with virtualization
        on). Recycled containers re-fade on scroll back into view.
    -->
    <Style Selector=":is(Panel).fade-items > ContentPresenter">
        <Setter Property="Opacity" Value="0" />
        <Style.Animations>
            <Animation Duration="0:0:0.2" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
